# Copy to .dev.vars for local `wrangler pages dev` runs (gitignored).
# The Workers AI binding needs no key here — it comes from `wrangler login`
# plus the --ai AI flag (or dashboard binding when deployed).
WORKERS_AI_MODEL=@cf/openai/gpt-oss-20b
# Set to 1 (or true) to disable all inference and use deterministic + fallback only:
PAW_FORCE_FALLBACK=
# --- Archived OpenAI variables (inactive; kept only for the archived implementation) ---
# OPENAI_API_KEY=
# OPENAI_VECTOR_STORE_ID=
# OPENAI_MODEL=
# Local diagnostics ONLY: includes the raw upstream error in fallback
# responses. NEVER set this on Cloudflare Preview or Production.
PAW_DEBUG_UPSTREAM=
