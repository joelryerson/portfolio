---
/**
 * Art-direction study · shared MOBILE canvas (static, 390×844, px-exact).
 * Same system rotated for the viewport: the field stays primary, the title
 * baseline sits on the datum, facts follow, and the four stations live in a
 * fixed bottom bar so switching never requires scrolling back to a menu.
 * Scoped to /experiments/resolve-art-direction. Not production.
 */
import homeLight from '../../assets/finderly/shots/home-light.webp';
import unitHifi from '../../assets/experiments/startupos-unit.webp';
import unitLofi from '../../assets/experiments/startupos-unit-lofi.webp';
import logoFinal from '../../assets/artparde/logo-final.png';
import studiesStrip from '../../assets/experiments/artparde-studies.webp';

interface Props {
  state: 'finderly' | 'asteri' | 'startupos' | 'artparde';
}
const { state } = Astro.props;

const projects = [
  {
    id: 'finderly',
    no: '01',
    name: 'Finderly',
    what: 'AI home-repair app by AI Vision Technologies.',
    role: 'Design Engineer · June–July 2026 · iOS, Android, web',
    decision:
      'Rebuilt the home screen around camera capture instead of a chat box; shipped a product-wide overhaul across 303 files in one month.',
  },
  {
    id: 'asteri',
    no: '02',
    name: 'Asteri AI',
    what: 'Work-intelligence platform for Fortune 500 life-sciences teams.',
    role: 'Design Engineer · six-week engagement · 2026',
    decision:
      'Built token infrastructure before restyling anything; the pilot migration shipped with zero visual change, on purpose.',
  },
  {
    id: 'startupos',
    no: '03',
    name: 'StartupOS',
    what: 'Founder-education platform.',
    role: 'Product Designer · 2022',
    decision:
      'Designed one reusable learning-unit template instead of bespoke units; the MVP shipped in five months.',
  },
  {
    id: 'artparde',
    no: '04',
    name: 'ArtPärdē',
    what: 'Performing-arts non-profit in San Francisco.',
    role: 'Brand & web · 2024, ongoing',
    decision:
      'Chose managed tooling a volunteer can run and spent the craft on the brand; the site is still their home two years on.',
  },
];
const active = projects.find((p) => p.id === state)!;
---

<div class={`artm s-${state}`} role="img" aria-label={`Mobile art-direction frame: ${state}`}>
  <header class="strip">
    <span class="who">Joel Ryerson</span>
    <span class="contact">Contact</span>
  </header>

  <!-- field -->
  {state === 'finderly' && (
    <div class="field">
      <div class="fin-primary" style={`background-image:url(${homeLight.src})`}></div>
      <div class="fin-dock" style={`background-image:url(${homeLight.src})`}></div>
    </div>
  )}
  {state === 'asteri' && (
    <div class="field">
      <p class="tok-label" style="top:58px; left:24px">--surface-raised</p>
      <span class="leader v" style="top:70px; left:52px; height:56px"></span>
      <div class="ast-card">
        <span>Active studies</span><b>128</b>
        <i class="cap">after · semantic tokens · zero visual change</i>
      </div>
      <span class="leader v" style="top:262px; left:300px; height:52px"></span>
      <p class="tok-label" style="top:322px; left:196px">--space-inset</p>
      <pre class="ast-css">.statCard &#123;
  background: var(--surface-raised);
&#125;</pre>
    </div>
  )}
  {state === 'startupos' && (
    <div class="field">
      <figure class="sos lofi" style={`background-image:url(${unitLofi.src})`}></figure>
      <figure class="sos hifi" style={`background-image:url(${unitHifi.src})`}></figure>
      <p class="sos-cap">iteration one → iteration five, shipped</p>
    </div>
  )}
  {state === 'artparde' && (
    <div class="field">
      <div class="ap-mark" style={`background-image:url(${logoFinal.src})`}></div>
      <div class="ap-band" style={`background-image:url(${studiesStrip.src})`}></div>
    </div>
  )}

  <h2 class="title">{active.name}</h2>
  <div class="datum"></div>

  <div class="facts">
    <p class="w">{active.what}</p>
    <p class="r">{active.role}</p>
    <p class="d">{active.decision}</p>
    <span class="case">Case study <b>→</b></span>
  </div>

  <!-- fixed station bar -->
  <nav class="bar" aria-label="Projects">
    {projects.map((p) => (
      <span class={`bstation ${p.id === state ? 'on' : ''}`}>
        <i class="tick"></i>
        <span class="s-no">{p.no}</span>
        <span class="s-name">{p.name}</span>
      </span>
    ))}
  </nav>
</div>

<style>
  .artm {
    position: relative;
    width: 390px;
    height: 844px;
    background: #f1f0ec;
    color: #111110;
    font-family: 'Schibsted X', system-ui, sans-serif;
    overflow: hidden;
    --line: #c9c6bb;
    --mute: #6f6c62;
    --signal: #e94a10;
    --mono: ui-monospace, 'SF Mono', Menlo, monospace;
  }
  .artm * { margin: 0; box-sizing: border-box; }

  .strip {
    position: absolute;
    top: 0; left: 20px; right: 20px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 3;
  }
  .who { font-size: 14.5px; font-weight: 700; }
  .contact { font-size: 13px; font-weight: 650; border-bottom: 2px solid var(--signal); padding-bottom: 1px; }

  .field { position: absolute; left: 0; right: 0; top: 50px; height: 420px; }

  .title {
    position: absolute;
    left: 20px;
    top: 424px;
    font-size: 42px;
    font-weight: 780;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .datum { position: absolute; left: 0; right: 0; top: 478px; height: 1.5px; background: #111110; }

  .facts { position: absolute; left: 20px; right: 20px; top: 496px; }
  .facts .w { font-size: 15px; font-weight: 600; line-height: 1.45; }
  .facts .r { font-size: 12.5px; color: var(--mute); margin-top: 5px; }
  .facts .d { font-size: 16px; line-height: 1.5; margin-top: 14px; letter-spacing: -0.004em; }
  .facts .case { display: inline-block; margin-top: 14px; font-size: 14px; font-weight: 700; }
  .facts .case b { color: var(--signal); }

  .bar {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 62px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    border-top: 1.5px solid #111110;
    background: #f1f0ec;
    box-shadow: 0 -10px 24px rgba(17, 17, 16, 0.06);
  }
  .bstation { position: relative; display: flex; align-items: baseline; gap: 5px; padding-top: 4px; }
  .bstation .tick { position: absolute; left: 0; top: -18px; width: 3px; height: 14px; background: transparent; }
  .bstation.on .tick { background: var(--signal); }
  .bstation .s-no { font-size: 10.5px; font-weight: 700; color: var(--mute); }
  .bstation .s-name { font-size: 12.5px; font-weight: 600; color: var(--mute); }
  .bstation.on .s-no { color: var(--signal); }
  .bstation.on .s-name { color: #111110; font-weight: 750; }

  /* ---- finderly ---- */
  .fin-primary {
    position: absolute;
    inset: 0 0 54px 0;
    background-size: 390px auto;
    background-position: 0 -64px;
    border-bottom: 1px solid var(--line);
  }
  .fin-dock {
    position: absolute;
    right: 16px; bottom: 34px;
    width: 240px; height: 46px;
    background-size: 253px auto;
    background-position: 50% 99.5%;
    background-color: #f6f0fb;
    border: 1px solid var(--line);
    border-radius: 10px;
    box-shadow: 0 8px 22px rgba(17, 17, 16, 0.14);
    z-index: 2;
  }

  /* ---- asteri ---- */
  .tok-label { position: absolute; font: 500 12.5px/1 var(--mono); }
  .leader.v { position: absolute; width: 1px; background: var(--line); }
  .leader.v::after {
    content: '';
    position: absolute;
    left: -2.5px; bottom: -2px;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--signal);
  }
  .ast-card {
    position: absolute;
    left: 40px; top: 134px;
    width: 260px;
    background: #f7f8fa;
    border: 1px solid #e2e4e9;
    border-radius: 10px;
    padding: 20px;
    box-shadow: 0 12px 30px rgba(17, 17, 16, 0.1);
  }
  .ast-card span { display: block; font-size: 13px; color: #6b7280; }
  .ast-card b { display: block; font-size: 26px; font-weight: 650; color: #111827; margin-top: 2px; }
  .ast-card .cap { display: block; font-style: normal; font-size: 11.5px; color: var(--mute); margin-top: 12px; }
  .ast-css { position: absolute; left: 24px; top: 330px; font: 400 11.5px/1.65 var(--mono); color: var(--mute); white-space: pre; }

  /* ---- startupos ---- */
  .sos { position: absolute; background-size: 100% auto; background-position: 0 0; border: 1px solid var(--line); }
  .sos.lofi { left: 20px; top: 22px; width: 210px; height: 250px; }
  .sos.hifi { right: 0; top: 96px; width: 240px; height: 268px; border-right: none; box-shadow: 0 12px 30px rgba(17, 17, 16, 0.13); }
  .sos-cap { position: absolute; left: 20px; top: 384px; font-size: 12px; font-weight: 600; color: var(--mute); }

  /* ---- artparde ---- */
  .ap-mark {
    position: absolute;
    left: 20px; top: 68px;
    width: 240px; height: 240px;
    border-radius: 50%;
    background-size: 114%;
    background-position: 50% 50%;
    box-shadow: 0 14px 34px rgba(17, 17, 16, 0.18);
    z-index: 2;
  }
  .ap-band {
    position: absolute;
    right: 0; top: 0;
    width: 140px; height: 420px;
    background-color: #131313;
    background-size: 330% auto;
    background-position: 30% 50%;
  }
</style>
