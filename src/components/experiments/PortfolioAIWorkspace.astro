---
/**
 * PortfolioAIWorkspace — shared floating AI workspace for the -ai
 * experiment variants. Interaction-shell phase 2 (usability pass):
 * host-owned default placement, responsive docking (reserve / overlay /
 * bottom fallback), Follow-active-project vs Dock-here, simplified
 * header with one overflow menu, minimized "Answer ready" state.
 * Deterministic scripted knowledge only — no external AI service.
 *
 * Host contract (window.PAW_HOST, defined BEFORE this script):
 *   {
 *     route:         string        — storage key suffix
 *     getProject():  'finderly'|'asteri'|'startupos'|'artparde'|''
 *     setProject(id): void         — must use the host's own select()
 *     onChange(cb):  void          — cb(id) on every project change
 *     minHostWidth:  px            — host is unusable narrower than this
 *     caps:          { follow, here, instrument }   — dock modes offered
 *     region(id?):   rect|null     — safe-inset rect of a project's
 *                                    physical region (id omitted = active)
 *     defaults(vp, pillSize): {
 *       minimized: {x,y} | {corner:'tl'|'tr'|'bl'|'br'},
 *       expanded:  place object ({kind:'snap'|'float'|'dock', ...}),
 *     }
 *     reserve(side|null): void     — 'left'|'right' body classes
 *   }
 * Theme: hosts set --paw-* custom properties on :root.
 */
---

<!-- minimized trigger -->
<div class="paw-pill" id="paw-pill">
  <button class="paw-pill-grip" id="paw-pill-grip" type="button" aria-label="Move the assistant trigger (drag or arrow keys)">
    <span aria-hidden="true">⠿</span>
  </button>
  <button class="paw-pill-open" id="paw-pill-open" type="button" aria-haspopup="dialog" aria-expanded="false">
    <span class="paw-spark" aria-hidden="true">✦</span>
    <span class="paw-pill-label" id="paw-pill-label">Ask about Joel</span>
    <span class="paw-pill-ctx" id="paw-pill-ctx"></span>
    <span class="paw-badge" id="paw-badge" hidden></span>
  </button>
</div>

<!-- expanded workspace -->
<section class="paw-panel" id="paw-panel" role="dialog" aria-label="Ask about Joel — AI guide" tabindex="-1" hidden>
  <header class="paw-head">
    <button class="paw-handle" id="paw-handle" type="button" aria-label="Move panel (drag, or use the options menu)">
      <span aria-hidden="true">⠿</span>
    </button>
    <p class="paw-title"><span class="paw-spark" aria-hidden="true">✦</span> Ask about Joel<span class="paw-title-ctx"> · <span id="paw-ctx">Overview</span></span></p>
    <button class="paw-btn paw-min" id="paw-min" type="button" aria-label="Minimize assistant">–</button>
    <div class="paw-menu-wrap">
      <button class="paw-btn" id="paw-more" type="button" aria-haspopup="menu" aria-expanded="false" aria-label="Position and options">⋯</button>
      <div class="paw-menu" id="paw-menu" role="menu" aria-label="Position and options" hidden>
        <button role="menuitem" data-pos="float" class="paw-desk">Float</button>
        <button role="menuitem" data-pos="follow" class="paw-desk" aria-label="Follow active project — the assistant anchors to whichever project is active and moves when it changes">Follow active project</button>
        <button role="menuitem" data-pos="here" class="paw-desk" aria-label="Dock here — the assistant anchors to the current project's physical region and stays there when the active project changes">Dock here</button>
        <button role="menuitem" data-pos="instrument" class="paw-desk">Dock to instrument</button>
        <button role="menuitem" data-pos="dock-left" class="paw-desk">Dock left</button>
        <button role="menuitem" data-pos="dock-right" class="paw-desk">Dock right</button>
        <button role="menuitem" data-pos="tl" class="paw-desk">Top left</button>
        <button role="menuitem" data-pos="tr" class="paw-desk">Top right</button>
        <button role="menuitem" data-pos="bl" class="paw-desk">Bottom left</button>
        <button role="menuitem" data-pos="br" class="paw-desk">Bottom right</button>
        <button role="menuitem" data-pos="pill-bl" class="paw-mob">Minimized dock: bottom left</button>
        <button role="menuitem" data-pos="pill-br" class="paw-mob">Minimized dock: bottom right</button>
        <button role="menuitem" data-pos="reset">Reset position</button>
        <button role="menuitem" data-pos="reset-convo">Reset conversation</button>
      </div>
    </div>
  </header>

  <p class="paw-note" id="paw-note" hidden><span id="paw-note-text"></span> · <button type="button" id="paw-float-now" class="paw-linklike">Float</button></p>

  <div class="paw-sheet-grip" id="paw-sheet-grip" aria-hidden="true"><span></span></div>

  <div class="paw-log" id="paw-log" role="log" aria-label="Conversation">
    <div class="paw-intro" id="paw-intro">
      <p class="paw-intro-note">AI guide grounded in verified portfolio information.</p>
      <p class="paw-intro-lede">A guide for evaluating Joel’s experience and role fit — nothing invented. This prototype runs on scripted local data; the live service comes later.</p>
      <p class="paw-intro-ctx" id="paw-intro-ctx"></p>
      <div class="paw-sugg" id="paw-sugg" aria-label="Suggested questions"></div>
    </div>
  </div>

  <div class="paw-cmp-bar" id="paw-cmp-bar" hidden>
    <button class="paw-chip" id="paw-cmp-toggle" type="button" aria-expanded="false">Compare Joel to a role</button>
  </div>
  <div class="paw-cmp" id="paw-cmp" hidden>
    <textarea id="paw-jd" maxlength="12000" rows="5" placeholder="Paste a job description…" aria-label="Job description to compare against Joel’s public evidence"></textarea>
    <div class="paw-cmp-row">
      <button type="button" id="paw-cmp-run" class="paw-send">Compare</button>
      <button type="button" id="paw-cmp-clear" class="paw-btn">Clear</button>
    </div>
  </div>

  <form class="paw-inputrow" id="paw-form">
    <input class="paw-input" id="paw-input" type="text" autocomplete="off"
      placeholder="Ask a hiring question…" aria-label="Ask a question about Joel" />
    <button class="paw-mic" type="button" aria-disabled="true" title="Voice coming later">
      <span aria-hidden="true">🎙</span><span class="paw-mic-note">Voice coming later</span>
    </button>
    <button class="paw-send" type="submit">Ask</button>
  </form>

  <button class="paw-resize" id="paw-resize" type="button" aria-label="Resize panel (drag)"></button>
</section>

<div class="paw-live" id="paw-live" aria-live="polite"></div>

<script is:inline>
  (() => {
    'use strict';
    const HOST = window.PAW_HOST;
    if (!HOST) return;
    const $ = (id) => document.getElementById(id);
    const pill = $('paw-pill'), pillOpen = $('paw-pill-open'), pillGrip = $('paw-pill-grip');
    const pillCtx = $('paw-pill-ctx'), pillLabel = $('paw-pill-label'), badge = $('paw-badge');
    const panel = $('paw-panel'), handle = $('paw-handle'), log = $('paw-log');
    const suggBox = $('paw-sugg'), introCtx = $('paw-intro-ctx'), ctxEl = $('paw-ctx');
    const form = $('paw-form'), input = $('paw-input'), live = $('paw-live');
    const menu = $('paw-menu'), posBtn = $('paw-more');
    const note = $('paw-note'), noteText = $('paw-note-text');
    const M = 20;                       // safe margin
    const SNAP = 72;                    // snap threshold
    const RESPONSE_LATENCY = 500;       // deterministic async delivery (models future real service)
    const NAMES = { finderly: 'Finderly', asteri: 'Asteri AI', startupos: 'StartupOS', artparde: 'ArtPärdē' };
    const CASE = { finderly: '/work/finderly/', asteri: '/work/asteri/', startupos: '/work/startup-platform/', artparde: '/work/artparde/' };
    const mobile = () => matchMedia('(max-width: 760px)').matches;
    const LIVE = !!HOST.live;   // grounded endpoint enabled for this host only

    /* ============================================================
       KNOWLEDGE — deterministic local data. Verified facts only.
       ============================================================ */
    const KB = {
      person: {
        name: 'Joel Ryerson',
        title: 'Product Designer & Design Engineer',
        technical: 'Implements what he designs: front-end work on Finderly, a hand-built portfolio with its own token system, AI-assisted build workflow that he directs.',
        limitations: [
          'Asteri’s public evidence is abstracted (diagrams and neutralized artifacts, no product screenshots) due to client constraints.',
          'StartupOS dates to 2022.',
          'Public outcome metrics are limited; case studies favor verifiable decisions over unverifiable numbers.',
        ],
      },
      projects: {
        finderly: {
          year: '2026', cat: 'AI home repair', role: 'Product design, UX/UI, and front-end implementation',
          owned: 'Product design end to end plus front-end implementation of the home experience.',
          shipped: 'The rebuilt home (light and dark), centered on starting a repair.',
          decision: 'Media-first, not chatbot-first: photo and video of the real problem as the primary interface.',
          incomplete: null,
          evidence: ['Shipped home · light/dark', 'Capture flow'],
        },
        asteri: {
          year: '2026', cat: 'AI work platform', role: 'Product design and design systems',
          owned: 'The styling audit, token architecture, and consolidation strategy in a six-week engagement.',
          shipped: 'Token foundation on pilot surfaces, zero visual diff; engineering continued the rollout after the engagement.',
          decision: 'Token infrastructure before restyling; core table intentionally unchanged.',
          incomplete: 'Homepage migration remained under review when the engagement ended.',
          evidence: ['Audit findings diagram', 'Two-paths diagram · shipped path', 'Token chain'],
        },
        startupos: {
          year: '2022', cat: 'Founder education', role: 'Product design',
          owned: 'The reusable learning-unit template system.',
          shipped: 'The template-built MVP, shipped in five months.',
          decision: 'Templates over bespoke screens.',
          incomplete: null,
          evidence: ['Template unit · hi-fi'],
        },
        artparde: {
          year: '2024', cat: 'Performing-arts nonprofit', role: 'Brand and web design',
          owned: 'The identity and the website, plus the platform choices behind them.',
          shipped: 'Identity and site, still in use and run by the organization without Joel.',
          decision: 'Webflow + fee-free Zeffy chosen deliberately for a volunteer-run nonprofit.',
          incomplete: null,
          evidence: ['Identity mark', 'Live site'],
        },
      },
    };

    const A = (id, label, match, text, evidence, actions, project) =>
      ({ id, label, match, text, evidence: evidence || [], actions: actions || [], project: project || null });
    const ANSWERS = [
      // ---- global ----
      A('own-global', 'What did Joel personally own?', ['personally own', 'personally owned', 'his role', 'responsib'],
        'Each case study names it precisely. Finderly: product design plus front-end implementation. Asteri: the styling audit, token architecture, and consolidation strategy. StartupOS: the template system. ArtPärdē: identity and site. Where a team continued the work — like Asteri’s rollout — the case study says so.',
        ['All four case studies'], [['show', 'finderly'], ['case', 'finderly']]),
      A('shipped-global', 'What actually shipped?', ['actually shipped', 'what shipped', 'went to production'],
        'Shipped and verifiable: Finderly’s rebuilt home (light and dark), Asteri’s token foundation on pilot surfaces with the rollout continuing after the engagement, StartupOS’s template-built MVP in 2022, and ArtPärdē’s identity and site, still in use today. Anything that did not ship is labeled as such.',
        ['Shipped home · light/dark', 'Two-paths diagram · shipped path'], [['show', 'asteri'], ['ask', 'incomplete']]),
      A('technical', 'How technical is Joel?', ['how technical', 'technical', 'can he code', 'does he code', 'engineer'],
        'Joel implements what he designs. On Finderly that meant front-end work in the product codebase; this portfolio itself is custom-coded with its own token system; and his build workflow is AI-assisted, with him directing the tools. The honest framing: a product designer with real front-end execution, not a platform engineer.',
        ['Finderly · implementation', 'This site · hand-built'], [['show', 'finderly'], ['ask', 'fit-de']]),
      A('systems', 'Show his strongest systems work', ['systems thinking', 'systems work', 'strongest systems', 'design system', 'design-systems'],
        'Asteri is the strongest systems evidence: audit, token architecture, consolidation, and a production rollout strategy inside six weeks. StartupOS shows the same instinct four years earlier as a template system. Together they make the pattern hard to dismiss as a one-off.',
        ['Audit findings diagram', 'Token chain'], [['show', 'asteri'], ['ask', 'cmp-ast-sos']]),
      A('fit-senior', 'Which project best fits a senior product-design role?', ['senior product', 'product-design role', 'best fits'],
        'Finderly, for a senior product-design role: recent, end to end, and shipped, with a defensible product decision at its center. Asteri is the supporting depth on systems, and ArtPärdē covers visual range.',
        ['Shipped home · light/dark'], [['show', 'finderly'], ['case', 'finderly']]),
      A('fit-de', 'Which project is most relevant to a design-engineering role?', ['design-engineering', 'design engineering', 'engineering role'],
        'For design engineering: Finderly plus this site itself. Finderly shows design and front-end implementation by the same person, and the portfolio is hand-built with a real token system. Asteri adds the token-pipeline thinking on top.',
        ['Finderly · implementation', 'This site · hand-built'], [['show', 'finderly'], ['case', 'finderly']]),
      A('cmp-fin-ast', 'Compare Finderly and Asteri', ['compare finderly and asteri', 'finderly vs asteri', 'asteri vs finderly'],
        'Finderly is product craft: a consumer home experience rebuilt end to end, design through front-end code, shipped in 2026. Asteri is infrastructure: a token foundation consolidated under an enterprise product without visible disruption, also 2026. One shows judgment in the interface; the other shows judgment underneath it.',
        ['Both case studies'], [['show', 'finderly'], ['show', 'asteri']]),
      A('cmp-fin-sos', 'Compare Finderly and StartupOS', ['compare finderly and startupos', 'finderly vs startupos', 'startupos vs finderly'],
        'Four years apart, same instinct, different altitude. StartupOS (2022) built reusable templates so a small team could ship an MVP in five months. Finderly (2026) rebuilt a shipped product’s home around the real job, and Joel implemented the front-end himself. The delta between them is the growth story.',
        ['Template unit · hi-fi', 'Shipped home · light/dark'], [['show', 'startupos'], ['show', 'finderly']]),
      A('cmp-ast-sos', 'Compare Asteri and StartupOS', ['compare asteri and startupos', 'asteri vs startupos', 'startupos vs asteri', 'compare with startupos'],
        'Both are structure over one-offs. StartupOS solved it at the content layer with templates in 2022; Asteri solved it at the styling layer with token architecture in 2026, shipped to production with zero visual difference. Asteri is the more rigorous version of the same conviction.',
        ['Two-paths diagram'], [['show', 'asteri'], ['show', 'startupos']]),
      A('incomplete', 'What work remained incomplete?', ['incomplete', 'unfinished', 'remained in progress', 'didn’t finish', 'didnt finish', 'not finished'],
        'Two things are stated openly. At Asteri, the homepage migration was still under review when the six-week engagement ended, and engineering continued the token rollout after Joel left. The portfolio treats both as facts, not footnotes.',
        ['Asteri case study · scope notes'], [['case', 'asteri']]),
      A('gaps', 'What are the honest gaps in Joel’s public portfolio?', ['honest gaps', 'limitations', 'public evidence', 'gaps', 'weakness'],
        'Three honest limits. Asteri’s public evidence is abstracted — diagrams and neutralized artifacts rather than product screenshots, due to client constraints. StartupOS dates to 2022. And public outcome metrics are limited across projects; the case studies favor verifiable decisions over unverifiable numbers.',
        ['Asteri · abstracted artifacts'], [['case', 'asteri']]),
      A('branding', 'Show me Joel’s branding work', ['branding', 'brand work', 'identity work', 'logo', 'visual identity'],
        'ArtPärdē is the branding evidence: identity, mark, and website for a performing-arts nonprofit, built so volunteers can run it themselves. It is deliberately the opposite texture from the enterprise product work.',
        ['Identity mark', 'Live site'], [['show', 'artparde'], ['case', 'artparde']]),
      A('open-relevant', 'Open the most relevant case study', ['open the most relevant', 'most relevant case', 'open case study', 'open the case'],
        '', [], []),
      // ---- finderly ----
      A('fin-own', 'What did Joel personally design?', ['finderly personally', 'personally design', 'own on finderly', 'design on finderly'],
        'Joel owned Finderly’s product design end to end: UX, UI, and the front-end implementation of what he designed. The defining call was rebuilding the home around starting a repair rather than a chat thread, so camera, video, and recent work sit at one clear entry point.',
        ['Shipped home · light/dark', 'Capture flow'], [['show', 'finderly'], ['case', 'finderly']], 'finderly'),
      A('fin-impl', 'What did he implement?', ['he implement', 'implement on finderly', 'implemented'],
        'Joel implemented the front-end of the home experience he designed, working in the product’s React Native codebase with a token pipeline connecting Figma to code. Design and implementation are the same person here, which is the point of the case study.',
        ['Finderly · implementation'], [['case', 'finderly']], 'finderly'),
      A('fin-home', 'What changed in the home experience?', ['changed in the home', 'home experience', 'previous home', 'old home'],
        'The previous home led with a chat thread, which buried the actual job. Joel rebuilt it around starting a repair: camera, video, and recent work are available from one clear entry point. The case study shows the former home against the shipped one.',
        ['Former home vs shipped home'], [['show', 'finderly'], ['case', 'finderly']], 'finderly'),
      A('fin-judgment', 'What demonstrates product judgment here?', ['product judgment', 'judgment here', 'judgement'],
        'In 2026 the default move is to make every AI product look like a chatbot. Joel argued the media — photo and video of the actual problem — was the product’s real interface, and rebuilt the home media-first. That decision survived shipping.',
        ['Media-first decision'], [['case', 'finderly']], 'finderly'),
      // ---- asteri ----
      A('ast-audit', 'What did Joel audit?', ['joel audit', 'audit at asteri', 'what did he audit'],
        'Joel audited the entire frontend’s styling sources and found systemic UI inconsistency: values restated inline per file with no shared source of truth. That audit is what justified building token infrastructure before restyling any screens.',
        ['Audit findings diagram'], [['show', 'asteri'], ['case', 'asteri']], 'asteri'),
      A('ast-shipped', 'What shipped versus remained in progress?', ['shipped versus', 'shipped at asteri', 'asteri shipped', 'versus remained'],
        'The consolidated token foundation shipped to production on pilot surfaces with zero visual difference, and engineering continued the rollout after Joel’s six-week engagement ended. The homepage migration was still under review at that point — the case study says so directly.',
        ['Two-paths diagram · shipped path'], [['show', 'asteri'], ['case', 'asteri']], 'asteri'),
      A('ast-tokens', 'What happened with the token architecture?', ['token architecture', 'token structure', 'happened with the token'],
        'Asteri is Joel’s clearest public design-systems example. He audited fragmented styling sources, explored an initial token structure, identified duplication in that approach, and consolidated it into a leaner foundation. The core Activity Database table was intentionally left unchanged, and the homepage migration remained under review when the engagement ended.',
        ['Token chain', 'Two-paths diagram'], [['show', 'asteri'], ['case', 'asteri'], ['ask', 'cmp-ast-sos']], 'asteri'),
      A('ast-table', 'Why was the core table left unchanged?', ['core table', 'table left unchanged', 'table unchanged'],
        'Leadership made the business-critical table off-limits — no redesign, restyle, or rebuild — and Joel planned the migration around that constraint rather than fighting it. His view in the case study: a system that only works when nothing is off-limits is not much of a system. The pilot migration elsewhere was appearance-unchanged by design: zero visual diff.',
        ['Two-paths diagram · pilot migration'], [['case', 'asteri']], 'asteri'),
      // ---- startupos ----
      A('sos-system', 'What reusable system did Joel create?', ['reusable system', 'system did joel create'],
        'Joel designed a reusable learning-unit template system rather than bespoke screens for each piece of content. The team assembled the MVP from those templates and shipped in five months.',
        ['Template unit · hi-fi'], [['show', 'startupos'], ['case', 'startupos']], 'startupos'),
      A('sos-template', 'How did the template structure support the MVP?', ['template structure', 'support the mvp', 'mvp'],
        'The template structure meant new content did not need new design: each learning unit drew from the same components and layout rules. That is what made a five-month MVP possible for a small team in 2022.',
        ['Template unit · hi-fi'], [['case', 'startupos']], 'startupos'),
      A('sos-role', 'What was Joel’s role?', ['joel’s role', 'joels role', 'role on startupos', 'his role on'],
        'Joel was the product designer on StartupOS in 2022. It is his strongest legacy piece and it is dated honestly: the portfolio leads with 2026 work and keeps this as evidence of range.',
        ['StartupOS case study'], [['show', 'startupos']], 'startupos'),
      A('sos-thinking', 'What does this demonstrate about product thinking?', ['product thinking', 'demonstrate about'],
        'It shows the same instinct that later shaped Asteri: invest in reusable structure instead of restyling one-offs. In 2022 that meant templates; in 2026 it meant token infrastructure.',
        ['Template unit · hi-fi'], [['ask', 'systems'], ['show', 'asteri']], 'startupos'),
      // ---- artparde ----
      A('ap-created', 'What did Joel create?', ['joel create', 'did joel create', 'create for artparde'],
        'Joel created ArtPärdē’s identity and built the website the organization still runs. Platform choices were part of the design: Webflow for maintainability and fee-free Zeffy for ticketing, chosen deliberately for a volunteer-run nonprofit.',
        ['Identity mark', 'Live site'], [['show', 'artparde'], ['case', 'artparde']], 'artparde'),
      A('ap-maintain', 'What makes the identity maintainable?', ['maintainable', 'maintain'],
        'Maintainability was designed in: a simple identity system the organization can apply themselves, on a platform non-designers can edit. They produce their own posters and promo within it, without Joel.',
        ['Live site'], [['case', 'artparde']], 'artparde'),
      A('ap-skills', 'What visual-design skills does this demonstrate?', ['visual-design skills', 'visual design', 'visual skills'],
        'It is the clearest public evidence of Joel’s visual range: a hand-drawn, color-forward identity system applied across the mark, the site, and event collateral — deliberately unlike the enterprise product work elsewhere in the portfolio.',
        ['Identity mark'], [['show', 'artparde']], 'artparde'),
      A('ap-inuse', 'What remained in use after delivery?', ['remained in use', 'after delivery', 'still in use'],
        'The identity and the website — two years on, the site is still the organization’s home and nothing has needed rescuing. Day-to-day it runs on tooling volunteers can operate, and Joel still keeps the site current when new shows land.',
        ['Live site'], [['case', 'artparde']], 'artparde'),
    ];
    const byId = Object.fromEntries(ANSWERS.map((a) => [a.id, a]));

    const GLOBAL_SUGG = ['own-global', 'shipped-global', 'technical', 'systems', 'fit-senior', 'cmp-fin-ast', 'gaps'];
    const PROJ_SUGG = {
      finderly: ['fin-own', 'fin-impl', 'fin-home', 'fin-judgment', 'cmp-fin-ast', 'gaps'],
      asteri: ['ast-audit', 'ast-shipped', 'ast-tokens', 'ast-table', 'cmp-ast-sos', 'gaps'],
      startupos: ['sos-system', 'sos-template', 'sos-role', 'sos-thinking', 'cmp-fin-sos', 'gaps'],
      artparde: ['ap-created', 'ap-maintain', 'ap-skills', 'ap-inuse', 'branding', 'gaps'],
    };

    const matchAnswer = (raw) => {
      const q = raw.toLowerCase().replace(/[?!.,;:'"’]/g, ' ').replace(/\s+/g, ' ').trim();
      if (!q) return null;
      if (q.includes('compare') || q.includes(' vs ')) {
        const has = (id) => q.includes(id === 'artparde' ? 'artp' : id === 'asteri' ? 'asteri' : id);
        if (has('finderly') && has('asteri')) return byId['cmp-fin-ast'];
        if (has('finderly') && has('startupos')) return byId['cmp-fin-sos'];
        if (has('asteri') && has('startupos')) return byId['cmp-ast-sos'];
      }
      let best = null, bestScore = 0;
      for (const a of ANSWERS) {
        let s = 0;
        for (const m of a.match) if (q.includes(m.toLowerCase().replace(/[’]/g, ''))) s += m.includes(' ') ? 3 : 1;
        if (a.project && q.includes(a.project === 'artparde' ? 'artp' : a.project)) s += 1;
        if (s > bestScore) { bestScore = s; best = a; }
      }
      return bestScore >= 1 ? best : null;
    };

    /* ============================================================
       STATE — v2 (versioned key: stale v1 placement data is ignored)
       ============================================================ */
    const KEY = 'paw2:' + HOST.route;
    const vw = () => window.innerWidth, vh = () => window.innerHeight;
    const pillSize = () => {
      const r = pill.getBoundingClientRect();
      return { w: r.width || 230, h: r.height || 50 };
    };
    const hostDefaults = () => HOST.defaults({ w: vw(), h: vh() }, pillSize());
    const freshState = () => ({
      v: 2, mode: 'min',
      place: hostDefaults().expanded,
      pillMode: 'host', pillCorner: 'br', pillXY: null,
      size: { w: 404, h: 560 }, sheet: 'half',
      convo: [], draft: '', jd: '', unread: 0, herePid: null,
    });
    let S;
    try {
      const raw = JSON.parse(sessionStorage.getItem(KEY) || 'null');
      S = raw && raw.v === 2 ? Object.assign(freshState(), raw) : freshState();
    } catch (e) { S = freshState(); }
    // validate stored place against host capabilities
    const placeValid = (p) => {
      if (!p || !p.kind) return false;
      if (p.kind === 'float') return Number.isFinite(p.x) && Number.isFinite(p.y);
      if (p.kind === 'snap') return ['tl', 'tr', 'lc', 'rc', 'bl', 'br'].includes(p.zone);
      if (p.kind === 'dock') {
        if (p.side === 'left' || p.side === 'right') return true;
        if (p.side === 'instrument') return !!HOST.caps.instrument;
        if (p.side === 'follow') return !!HOST.caps.follow;
        if (p.side === 'here') return !!HOST.caps.here && !!S.herePid;
        return false;
      }
      return false;
    };
    if (!placeValid(S.place)) S.place = hostDefaults().expanded;
    const save = () => { try { sessionStorage.setItem(KEY, JSON.stringify(S)); } catch (e) {} };

    /* ============================================================
       GEOMETRY — float / snap / responsive dock, viewport clamped
       ============================================================ */
    const size = () => {
      const w = Math.min(Math.max(S.size.w, 340), Math.min(560, vw() - 2 * M));
      const h = Math.min(Math.max(S.size.h, 420), Math.max(360, vh() - 2 * M));
      return { w, h };
    };
    const zoneXY = (zone, w, h) => ({
      tl: [M, M], tr: [vw() - w - M, M],
      lc: [M, Math.max(M, (vh() - h) / 2)], rc: [vw() - w - M, Math.max(M, (vh() - h) / 2)],
      bl: [M, vh() - h - M], br: [vw() - w - M, vh() - h - M],
    })[zone];
    const clamp = (x, y, w, h) => [
      Math.min(Math.max(x, M), Math.max(M, vw() - w - M)),
      Math.min(Math.max(y, M), Math.max(M, vh() - h - M)),
    ];

    // responsive dock policy: reserve on wide, overlay on medium, bottom on narrow/short
    const dockPolicy = (w) => {
      if (vh() < 540 || vw() < 720) return 'bottom';
      return vw() - (w + 2 * M + 12) >= HOST.minHostWidth ? 'reserve' : 'overlay';
    };
    const NOTE_LABEL = { left: 'Docked left', right: 'Docked right', instrument: 'Docked to instrument', follow: 'Following active project', here: 'Docked here' };

    const layout = () => {
      if (mobile()) { layoutMobile(); return; }
      panel.classList.remove('paw-sheet');
      const { w, h } = size();
      let x, y, W = w, H = h, dock = null, reserveSide = null, noteMsg = '';
      if (S.place.kind === 'dock') {
        dock = S.place.side;
        if (dock === 'follow' || dock === 'here') {
          const pid = dock === 'here' ? S.herePid : (HOST.getProject() || null);
          const rect = pid ? HOST.region(pid) : HOST.region();
          if (rect && rect.width >= w + 24 && rect.height >= 444) {
            // region is large enough: dock inside its safe area
            W = Math.min(w, rect.width - 24);
            H = Math.min(h, rect.height - 24);
            [x, y] = clamp(rect.right - W - 12, rect.top + 12, W, H);
            noteMsg = NOTE_LABEL[dock];
          } else if (rect) {
            // region collapsed below the panel's usable minimum: keep the
            // association but sit just beside it (toward the viewport
            // center), at full usable size — never shrink below minimum
            const cx = rect.left + rect.width / 2;
            const cy = rect.top + rect.height / 2;
            const px = cx < vw() / 2 ? rect.right + 12 : rect.left - W - 12;
            const py = cy < vh() / 2 ? rect.top : rect.bottom - H;
            [x, y] = clamp(px, py, W, H);
            noteMsg = 'Docked near this region';
          } else { // no region available: quiet fallback to a safe snap
            [x, y] = zoneXY('br', W, H);
            noteMsg = NOTE_LABEL[dock] + ' · no anchor available';
          }
        } else {
          const edge = dock === 'left' ? 'left' : 'right';
          const policy = dockPolicy(w);
          if (policy === 'bottom') {
            W = Math.min(w, vw() - 2 * M);
            H = Math.min(h, Math.max(360, vh() - 2 * M));
            x = vw() - W - M; y = vh() - H - M;
            noteMsg = NOTE_LABEL[dock] + ' · limited space, moved to bottom';
          } else {
            W = w; H = vh() - 2 * M;
            x = edge === 'left' ? M : vw() - W - M; y = M;
            if (policy === 'reserve') { reserveSide = edge; noteMsg = NOTE_LABEL[dock]; }
            else noteMsg = NOTE_LABEL[dock] + ' · overlay (limited space)';
          }
        }
      } else if (S.place.kind === 'snap') {
        [x, y] = zoneXY(S.place.zone, W, H);
      } else {
        [x, y] = clamp(S.place.x, S.place.y, W, H);
      }
      Object.assign(panel.style, { left: x + 'px', top: y + 'px', width: W + 'px', height: H + 'px', right: 'auto', bottom: 'auto' });
      panel.classList.toggle('paw-docked', !!dock);
      panel.classList.toggle('paw-overlay', !!dock && !reserveSide);
      note.hidden = !dock;
      noteText.textContent = noteMsg;
      HOST.reserve(reserveSide);
    };
    const layoutMobile = () => {
      panel.classList.add('paw-sheet');
      panel.classList.remove('paw-docked', 'paw-overlay');
      note.hidden = true;
      HOST.reserve(null);
      panel.style.left = '0'; panel.style.right = '0'; panel.style.bottom = '0'; panel.style.top = 'auto'; panel.style.width = 'auto';
      panel.style.height = S.sheet === 'full' ? 'calc(100dvh - 52px)' : '58dvh';
    };
    const applyCorner = (c) => {
      pill.style.left = c.endsWith('l') ? M + 'px' : 'auto';
      pill.style.right = c.endsWith('r') ? M + 'px' : 'auto';
      pill.style.top = c.startsWith('t') ? M + 'px' : 'auto';
      pill.style.bottom = c.startsWith('b') ? M + 'px' : 'auto';
    };
    const layoutPill = () => {
      if (mobile()) { applyCorner(['bl', 'br'].includes(S.pillCorner) ? S.pillCorner : 'br'); return; }
      if (S.pillMode === 'corner') { applyCorner(S.pillCorner); return; }
      if (S.pillMode === 'custom' && S.pillXY) {
        const { w, h } = pillSize();
        const [x, y] = clamp(S.pillXY.x, S.pillXY.y, w, h);
        Object.assign(pill.style, { left: x + 'px', top: y + 'px', right: 'auto', bottom: 'auto' });
        return;
      }
      // host default placement
      const d = hostDefaults().minimized;
      if (d.corner) { applyCorner(d.corner); return; }
      const { w, h } = pillSize();
      const [x, y] = clamp(d.x, d.y, w, h);
      Object.assign(pill.style, { left: x + 'px', top: y + 'px', right: 'auto', bottom: 'auto' });
    };

    /* ============================================================
       UNREAD / ANSWER-READY
       ============================================================ */
    const updatePill = () => {
      if (S.unread > 0) {
        pillLabel.textContent = 'Answer ready';
        pillCtx.textContent = '';
        badge.hidden = S.unread < 2;
        badge.textContent = String(S.unread);
      } else {
        pillLabel.textContent = 'Ask about Joel';
        badge.hidden = true;
        renderContext();
      }
    };
    const markUnread = () => {
      S.unread += 1; save();
      updatePill();
      live.textContent = S.unread === 1 ? 'Answer ready in the assistant' : S.unread + ' answers ready in the assistant';
    };

    /* ============================================================
       MODE (min / exp) + focus contract
       ============================================================ */
    const setMode = (mode, focusTarget) => {
      S.mode = mode;
      const exp = mode === 'exp';
      if (exp && S.unread) S.unread = 0;
      save();
      panel.hidden = !exp;
      pill.hidden = exp;
      pillOpen.setAttribute('aria-expanded', String(exp));
      if (exp) { updatePill(); layout(); log.scrollTop = log.scrollHeight; (focusTarget || panel).focus(); }
      else { HOST.reserve(null); updatePill(); layoutPill(); (focusTarget || pillOpen).focus(); }
    };

    /* ============================================================
       CONVERSATION
       ============================================================ */
    const esc = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    const renderMsg = (m) => {
      const el = document.createElement('div');
      el.className = 'paw-msg paw-msg-' + m.who;
      if (m.who === 'u') { el.textContent = m.text; return el; }
      let html = '<p>' + esc(m.text).replace(/\n/g, '<br>') + '</p>';
      if (m.evidence && m.evidence.length) html += '<p class="paw-evd">' + m.evidence.map((e) => {
        if (typeof e === 'string') return '<span>Evidence · ' + esc(e) + '</span>';
        const label = 'Evidence · ' + esc(e.label || '');
        const url = e.url && /^\/work\//.test(e.url) ? e.url : null;
        return url
          ? '<a href="' + esc(url) + '" title="' + esc(e.relevance || '') + '">' + label + '</a>'
          : '<span title="' + esc(e.relevance || '') + '">' + label + '</span>';
      }).join('') + '</p>';
      if (m.limitations && m.limitations.length) html += '<p class="paw-limits">' + m.limitations.map(esc).join('<br>') + '</p>';
      if (m.confidence && m.confidence !== 'high') html += '<p class="paw-conf">Confidence: ' + esc(m.confidence) + '</p>';
      el.innerHTML = html;
      if (m.actions && m.actions.length) {
        const row = document.createElement('div');
        row.className = 'paw-acts';
        for (const [kind, arg] of m.actions) {
          if (kind === 'case') {
            const a = document.createElement('a');
            a.className = 'paw-chip'; a.href = CASE[arg];
            a.textContent = 'Open ' + NAMES[arg] + ' case study';
            row.appendChild(a);
          } else {
            const b = document.createElement('button');
            b.type = 'button'; b.className = 'paw-chip';
            b.textContent = kind === 'show' ? 'Show ' + NAMES[arg] : kind === 'askfree' ? arg : (byId[arg] ? byId[arg].label : arg);
            b.addEventListener('click', () => {
              if (kind === 'show') {
                HOST.setProject(arg);
                live.textContent = 'Now showing ' + NAMES[arg];
              } else if (kind === 'askfree') submitQuestion(arg);
              else answer(byId[arg], byId[arg].label);
            });
            row.appendChild(b);
          }
        }
        el.appendChild(row);
      }
      if (m.followUps && m.followUps.length) {
        const fu = document.createElement('div');
        fu.className = 'paw-acts';
        for (const q of m.followUps) {
          const b = document.createElement('button');
          b.type = 'button'; b.className = 'paw-chip';
          b.textContent = q;
          b.addEventListener('click', () => submitQuestion(q));
          fu.appendChild(b);
        }
        el.appendChild(fu);
      }
      return el;
    };
    const push = (m) => {
      S.convo.push(m);
      if (S.convo.length > 40) S.convo = S.convo.slice(-40);
      save();
      log.appendChild(renderMsg(m));
      log.scrollTop = log.scrollHeight;
      if (m.who === 'a' && panel.hidden) markUnread();
    };
    // responses are delivered asynchronously (deterministic latency) so the
    // minimized "Answer ready" state is reachable, matching a future real service
    const respond = (m) => setTimeout(() => push(m), RESPONSE_LATENCY);
    const answer = (a, asked) => {
      push({ who: 'u', text: asked });
      if (!a) {
        respond({ who: 'a', text: 'This prototype’s guide is scripted and covers Joel’s four public projects: what he owned, what shipped, how technical he is, and the honest limits of the public evidence. Try one of the suggested questions below, or name a project.', evidence: [], actions: [['ask', 'own-global'], ['ask', 'gaps']] });
        return;
      }
      if (a.id === 'open-relevant') {
        const p = HOST.getProject() || 'finderly';
        respond({ who: 'a', text: (HOST.getProject() ? NAMES[p] + ' is active, so its case study is the direct next step.' : 'With nothing selected, Finderly is the strongest starting point: recent, end to end, and shipped.'), evidence: [], actions: [['case', p], ['show', p]] });
        return;
      }
      respond({ who: 'a', text: a.text, evidence: a.evidence, actions: a.actions });
    };

    /* ============================================================
       LIVE grounded requests (Focus Matrix only) — cancellable,
       duplicate-safe, falls back to the scripted summary
       ============================================================ */
    const FALLBACK_NOTE = 'The live AI guide is temporarily unavailable, so this answer uses Joel’s verified portfolio summary.';
    let inflight = null;
    const setBusy = (b) => {
      form.querySelector('.paw-send').disabled = b;
      const run = $('paw-cmp-run');
      if (run) run.disabled = b;
    };
    const cancelInflight = () => {
      if (!inflight) return;
      inflight.userCancelled = true;
      inflight.controller.abort();
      inflight.row.remove();
      inflight = null;
      setBusy(false);
    };
    const loadingRow = () => {
      const el = document.createElement('div');
      el.className = 'paw-loading';
      const s = document.createElement('span');
      s.textContent = 'Finding relevant portfolio evidence…';
      const c = document.createElement('button');
      c.type = 'button'; c.className = 'paw-linklike'; c.textContent = 'Cancel';
      c.addEventListener('click', cancelInflight);
      el.append(s, c);
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
      return el;
    };
    const errorRow = (question, mode, jd, msg) => {
      const el = document.createElement('div');
      el.className = 'paw-loading paw-error';
      const s = document.createElement('span');
      s.textContent = msg || 'The guide could not answer just now.';
      const r = document.createElement('button');
      r.type = 'button'; r.className = 'paw-linklike'; r.textContent = 'Retry';
      r.addEventListener('click', () => { el.remove(); liveAsk(question, mode, jd, true); });
      el.append(s, r);
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
    };
    const scriptedFallback = (question, mode) => {
      if (mode === 'role_comparison') {
        push({ who: 'a', text: 'Role comparison needs the live guide, which is temporarily unavailable. In the meantime, the four case studies are the verified evidence base for any role match.', evidence: ['All four case studies'], actions: [['case', 'finderly'], ['case', 'asteri'], ['case', 'startupos'], ['case', 'artparde']], limitations: [FALLBACK_NOTE] });
        return;
      }
      const a = matchAnswer(question);
      if (!a) { push({ who: 'a', text: 'The verified summary covers Joel’s four public projects: what he owned, what shipped, and the honest limits of the public evidence. Try one of the suggested questions, or name a project.', evidence: [], actions: [['ask', 'own-global'], ['ask', 'gaps']], limitations: [FALLBACK_NOTE] }); return; }
      if (a.id === 'open-relevant') { answer(a, question); return; }
      push({ who: 'a', text: a.text, evidence: a.evidence, actions: a.actions, limitations: [FALLBACK_NOTE] });
    };
    const liveAsk = async (question, mode, jd, isRetry) => {
      if (inflight) return; // duplicate-submission guard
      if (!isRetry) push({ who: 'u', text: mode === 'role_comparison' ? 'Compare Joel to a role (job description pasted)' : question });
      const row = loadingRow();
      setBusy(true);
      const controller = new AbortController();
      const requestId = 'r' + Math.random().toString(36).slice(2) + Date.now().toString(36);
      const me = { controller, row, requestId, userCancelled: false };
      inflight = me;
      const timeout = setTimeout(() => { if (inflight === me) controller.abort(); }, 30000);
      let res = null, data = null;
      try {
        res = await fetch('/api/portfolio-ai', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          signal: controller.signal,
          body: JSON.stringify({
            requestId,
            question: mode === 'role_comparison' ? '' : question,
            jobDescription: mode === 'role_comparison' ? jd : '',
            mode: mode === 'role_comparison' ? 'role_comparison' : 'question',
            project: HOST.getProject() || '',
            context: S.convo.slice(-8).map((m) => ({ who: m.who, text: String(m.text || '').slice(0, 1200) })),
          }),
        });
        data = await res.json().catch(() => null);
      } catch (err) {
        clearTimeout(timeout);
        if (me.userCancelled || inflight !== me) return; // cancelled: no stale insert
        inflight = null; setBusy(false); row.remove();
        scriptedFallback(question, mode);
        return;
      }
      clearTimeout(timeout);
      if (me.userCancelled || inflight !== me) return; // cancelled mid-flight
      inflight = null; setBusy(false); row.remove();
      if (!res.ok) { errorRow(question, mode, jd, data && data.error ? data.error : null); return; }
      if (!data || data.mode === 'fallback') { scriptedFallback(question, mode); return; }
      push({
        who: 'a',
        text: data.answer,
        evidence: (data.evidence || []).map((e) => ({ label: e.sourceLabel, url: e.url, relevance: e.relevance })),
        actions: (data.actions || []).map((a) => { const i = a.indexOf(':'); const k = a.slice(0, i); return [k === 'ask' ? 'askfree' : k, a.slice(i + 1)]; }),
        followUps: data.followUps || [],
        limitations: data.limitations || [],
        confidence: data.confidence,
      });
    };
    const submitQuestion = (q) => { if (LIVE) liveAsk(q, 'question'); else answer(matchAnswer(q), q); };

    const renderSuggestions = () => {
      const p = HOST.getProject();
      const list = p ? PROJ_SUGG[p] : GLOBAL_SUGG;
      suggBox.innerHTML = '';
      for (const id of list) {
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'paw-chip';
        b.textContent = byId[id].label;
        b.addEventListener('click', () => submitQuestion(byId[id].label));
        suggBox.appendChild(b);
      }
    };
    const renderContext = () => {
      const p = HOST.getProject();
      const name = p ? NAMES[p] : '';
      ctxEl.textContent = p ? 'Viewing ' + name : 'Overview';
      if (S.unread === 0) pillCtx.textContent = p ? ' · ' + name : '';
      introCtx.textContent = p
        ? 'You are viewing ' + name + ' (' + KB.projects[p].year + ' · ' + KB.projects[p].cat + '). ' + KB.projects[p].role + '.'
        : 'Nothing selected yet — questions below cover the whole portfolio.';
      renderSuggestions();
    };
    const restoreConvo = () => {
      for (const m of S.convo) log.appendChild(renderMsg(m));
      if (S.convo.length) log.scrollTop = log.scrollHeight;
    };

    /* ============================================================
       DRAG (Pointer Events) — panel handle, pill grip, resize, sheet
       ============================================================ */
    const dragState = { active: null };
    const beginDrag = (kind, e) => {
      if (kind === 'panel' && (mobile() || panel.classList.contains('paw-docked'))) return;
      if (kind === 'pill' && !panel.hidden) return;
      if (kind === 'pill' && mobile()) return;
      e.preventDefault();
      const target = e.currentTarget;
      try { target.setPointerCapture(e.pointerId); } catch (err) {}
      const r = (kind === 'pill' ? pill : panel).getBoundingClientRect();
      dragState.active = {
        kind, id: e.pointerId, sx: e.clientX, sy: e.clientY, ox: r.left, oy: r.top, ow: r.width, oh: r.height,
        prevPlace: JSON.parse(JSON.stringify(S.place)), prevPillMode: S.pillMode, prevPillCorner: S.pillCorner,
        prevPillXY: S.pillXY ? Object.assign({}, S.pillXY) : null, prevSize: Object.assign({}, S.size), prevSheet: S.sheet,
      };
      document.body.classList.add('paw-dragging');
    };
    const onMove = (e) => {
      const d = dragState.active;
      if (!d || e.pointerId !== d.id) return;
      const dx = e.clientX - d.sx, dy = e.clientY - d.sy;
      if (d.kind === 'panel') {
        const { w, h } = size();
        const [x, y] = clamp(d.ox + dx, d.oy + dy, w, h);
        S.place = { kind: 'float', x, y };
        panel.style.left = x + 'px'; panel.style.top = y + 'px';
      } else if (d.kind === 'pill') {
        const [x, y] = clamp(d.ox + dx, d.oy + dy, d.ow, d.oh);
        Object.assign(pill.style, { left: x + 'px', top: y + 'px', right: 'auto', bottom: 'auto' });
      } else if (d.kind === 'resize') {
        S.size = { w: d.ow + dx, h: d.oh + dy };
        const { w, h } = size();
        S.size = { w, h };
        panel.style.width = w + 'px'; panel.style.height = h + 'px';
        const r = panel.getBoundingClientRect();
        const [x, y] = clamp(r.left, r.top, w, h);
        panel.style.left = x + 'px'; panel.style.top = y + 'px';
      } else if (d.kind === 'sheet') {
        const hpx = Math.min(Math.max(d.oh - dy, vh() * 0.34), vh() - 52);
        panel.style.height = hpx + 'px';
      }
    };
    const endDrag = (e, cancelled) => {
      const d = dragState.active;
      if (!d || (e && e.pointerId !== d.id)) return;
      dragState.active = null;
      document.body.classList.remove('paw-dragging');
      if (cancelled) {
        S.place = d.prevPlace; S.pillMode = d.prevPillMode; S.pillCorner = d.prevPillCorner;
        S.pillXY = d.prevPillXY; S.size = d.prevSize; S.sheet = d.prevSheet;
        save(); if (!panel.hidden) layout(); layoutPill();
        return;
      }
      if (d.kind === 'panel') {
        const { w, h } = size();
        const r = panel.getBoundingClientRect();
        let snapped = null, bestDist = SNAP + 1;
        for (const z of ['tl', 'tr', 'lc', 'rc', 'bl', 'br']) {
          const [zx, zy] = zoneXY(z, w, h);
          const dist = Math.hypot(r.left - zx, r.top - zy);
          if (dist < bestDist) { bestDist = dist; snapped = z; }
        }
        if (snapped) S.place = { kind: 'snap', zone: snapped };
        save(); layout();
      } else if (d.kind === 'pill') {
        const r = pill.getBoundingClientRect();
        // near a corner → corner mode; otherwise keep the custom position
        const corners = ['tl', 'tr', 'bl', 'br'];
        let best = null, bd = 96;
        for (const c of corners) {
          const px = c.endsWith('l') ? M : vw() - M - r.width;
          const py = c.startsWith('t') ? M : vh() - M - r.height;
          const dist = Math.hypot(r.left - px, r.top - py);
          if (dist < bd) { bd = dist; best = c; }
        }
        if (best) { S.pillMode = 'corner'; S.pillCorner = best; }
        else { S.pillMode = 'custom'; S.pillXY = { x: r.left, y: r.top }; }
        save(); layoutPill();
      } else if (d.kind === 'resize') {
        save();
      } else if (d.kind === 'sheet') {
        const hpx = panel.getBoundingClientRect().height;
        S.sheet = hpx > vh() * 0.72 ? 'full' : 'half';
        save(); layoutMobile();
      }
    };
    handle.addEventListener('pointerdown', (e) => beginDrag('panel', e));
    pillGrip.addEventListener('pointerdown', (e) => beginDrag('pill', e));
    $('paw-resize').addEventListener('pointerdown', (e) => beginDrag('resize', e));
    $('paw-sheet-grip').addEventListener('pointerdown', (e) => { if (mobile()) beginDrag('sheet', e); });
    for (const el of [handle, pillGrip, $('paw-resize'), $('paw-sheet-grip')]) {
      el.addEventListener('pointermove', onMove);
      el.addEventListener('pointerup', (e) => endDrag(e, false));
      el.addEventListener('pointercancel', (e) => endDrag(e, true));
    }
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && dragState.active) { endDrag({ pointerId: dragState.active.id }, true); e.stopPropagation(); }
    }, true);
    pillGrip.addEventListener('keydown', (e) => {
      const map = { ArrowLeft: 'l', ArrowRight: 'r', ArrowUp: 't', ArrowDown: 'b' };
      if (!map[e.key]) return;
      e.preventDefault();
      const cur = S.pillMode === 'corner' ? S.pillCorner : 'br';
      let [v, hz] = [cur[0], cur[1]];
      if (map[e.key] === 'l') hz = 'l'; if (map[e.key] === 'r') hz = 'r';
      if (map[e.key] === 't' && !mobile()) v = 't'; if (map[e.key] === 'b') v = 'b';
      S.pillMode = 'corner'; S.pillCorner = v + hz; save(); layoutPill();
    });

    /* ============================================================
       OVERFLOW MENU
       ============================================================ */
    const closeMenu = () => { menu.hidden = true; posBtn.setAttribute('aria-expanded', 'false'); };
    const filterMenu = () => {
      const caps = HOST.caps || {};
      const vis = {
        follow: !mobile() && caps.follow,
        here: !mobile() && caps.here,
        instrument: !mobile() && caps.instrument,
      };
      for (const b of menu.querySelectorAll('[data-pos]')) {
        const p = b.dataset.pos;
        if (p in vis) b.hidden = !vis[p];
      }
    };
    posBtn.addEventListener('click', () => {
      if (menu.hidden) { filterMenu(); menu.hidden = false; posBtn.setAttribute('aria-expanded', 'true'); }
      else closeMenu();
      if (!menu.hidden) {
        const first = [...menu.querySelectorAll('button')].find((b) => !b.hidden && b.offsetParent !== null);
        if (first) first.focus();
      }
    });
    menu.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { closeMenu(); posBtn.focus(); e.stopPropagation(); }
      if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
        e.preventDefault();
        const items = [...menu.querySelectorAll('button')].filter((b) => !b.hidden && b.offsetParent !== null);
        const i = items.indexOf(document.activeElement);
        items[(i + (e.key === 'ArrowDown' ? 1 : items.length - 1)) % items.length].focus();
      }
    });
    document.addEventListener('click', (e) => { if (!menu.hidden && !e.target.closest('.paw-menu-wrap')) closeMenu(); });
    menu.addEventListener('click', (e) => {
      const b = e.target.closest('[data-pos]');
      if (!b) return;
      const pos = b.dataset.pos;
      if (pos === 'reset') {
        S.place = hostDefaults().expanded;
        S.pillMode = 'host'; S.pillCorner = 'br'; S.pillXY = null;
        S.size = { w: 404, h: 560 }; S.sheet = 'half'; S.herePid = null;
      } else if (pos === 'reset-convo') {
        S.convo = []; S.draft = ''; S.unread = 0; input.value = '';
        log.querySelectorAll('.paw-msg').forEach((m) => m.remove());
        updatePill();
      } else if (pos === 'float') { const r = panel.getBoundingClientRect(); S.place = { kind: 'float', x: r.left, y: r.top }; }
      else if (pos === 'follow') S.place = { kind: 'dock', side: 'follow' };
      else if (pos === 'here') { S.herePid = HOST.getProject() || null; S.place = S.herePid ? { kind: 'dock', side: 'here' } : S.place; }
      else if (pos === 'instrument') S.place = { kind: 'dock', side: 'instrument' };
      else if (pos === 'dock-left') S.place = { kind: 'dock', side: 'left' };
      else if (pos === 'dock-right') S.place = { kind: 'dock', side: 'right' };
      else if (pos === 'pill-bl') { S.pillMode = 'corner'; S.pillCorner = 'bl'; }
      else if (pos === 'pill-br') { S.pillMode = 'corner'; S.pillCorner = 'br'; }
      else S.place = { kind: 'snap', zone: pos };
      save(); if (!panel.hidden) layout(); layoutPill(); closeMenu(); posBtn.focus();
    });
    $('paw-float-now').addEventListener('click', () => {
      const r = panel.getBoundingClientRect();
      const { w, h } = size();
      const [x, y] = clamp(r.left, r.top, w, h);
      S.place = { kind: 'float', x, y };
      save(); layout();
    });

    /* ============================================================
       WIRING
       ============================================================ */
    pillOpen.addEventListener('click', () => setMode('exp'));
    $('paw-min').addEventListener('click', () => setMode('min'));
    panel.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !dragState.active) {
        if (!menu.hidden) { closeMenu(); posBtn.focus(); return; }
        setMode('min');
      }
    });
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      if (!q) return;
      input.value = ''; S.draft = ''; save();
      submitQuestion(q);
    });
    input.addEventListener('input', () => { S.draft = input.value; save(); });

    HOST.onChange(() => {
      renderContext();
      if (S.unread === 0) updatePill();
      // host layouts animate (~600ms): re-measure after the transition settles
      const settle = () => {
        if (!panel.hidden && S.place.kind === 'dock' && (S.place.side === 'follow' || S.place.side === 'here')) layout();
        if (panel.hidden && S.pillMode === 'host') layoutPill();
      };
      settle();
      setTimeout(settle, 380);
      setTimeout(settle, 750);
    });
    window.addEventListener('resize', () => { layoutPill(); if (!panel.hidden) layout(); });

    // compare-to-role UI (live host only)
    if (LIVE) {
      $('paw-cmp-bar').hidden = false;
      document.querySelector('.paw-intro-note').textContent = 'AI guide grounded in Joel’s approved professional materials.';
      document.querySelector('.paw-intro-lede').textContent = 'Ask hiring questions about Joel’s work; answers cite his approved public evidence. Questions are answered using Joel’s approved professional materials, and this prototype does not intentionally store conversation transcripts. The guide is not a substitute for speaking with Joel.';
      const jdEl = $('paw-jd');
      jdEl.value = S.jd || '';
      $('paw-cmp-toggle').addEventListener('click', () => {
        const open = $('paw-cmp').hidden;
        $('paw-cmp').hidden = !open;
        $('paw-cmp-toggle').setAttribute('aria-expanded', String(open));
        if (open) jdEl.focus();
      });
      jdEl.addEventListener('input', () => { S.jd = jdEl.value; save(); });
      $('paw-cmp-run').addEventListener('click', () => {
        const jd = jdEl.value.trim();
        if (jd) liveAsk('', 'role_comparison', jd);
      });
      $('paw-cmp-clear').addEventListener('click', () => { jdEl.value = ''; S.jd = ''; save(); });
    }

    // init
    input.value = S.draft || '';
    renderContext();
    restoreConvo();
    updatePill();
    layoutPill();
    if (S.mode === 'exp') { S.unread = 0; save(); panel.hidden = false; pill.hidden = true; pillOpen.setAttribute('aria-expanded', 'true'); updatePill(); layout(); }
  })();
</script>

