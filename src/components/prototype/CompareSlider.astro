---
/**
 * PROTOTYPE-SCOPED before/after comparator. Progressive enhancement:
 * default render is a labeled static side-by-side pair; JS upgrades it
 * to a draggable divider (native <input type=range> drives everything,
 * so keyboard, touch, and AT semantics come from the platform).
 * Not production; lives and dies with /prototype/monograph.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Annotation {
  /** percent coords on the AFTER image */
  x: number;
  y: number;
  n: number;
}

interface Props {
  before: ImageMetadata;
  after: ImageMetadata;
  beforeAlt: string;
  afterAlt: string;
  beforeLabel: string;
  afterLabel: string;
  annotations?: Annotation[];
}

const { before, after, beforeAlt, afterAlt, beforeLabel, afterLabel, annotations = [] } = Astro.props;
---

<figure class="cmp" data-compare>
  <!-- default / no-JS: labeled static pair -->
  <div class="cmp-fallback">
    <figure>
      <Image src={before} alt={beforeAlt} widths={[480, 800]} sizes="(max-width: 700px) 44vw, 320px" />
      <figcaption>{beforeLabel}</figcaption>
    </figure>
    <figure>
      <Image src={after} alt={afterAlt} widths={[480, 800]} sizes="(max-width: 700px) 44vw, 320px" />
      <figcaption>{afterLabel}</figcaption>
    </figure>
  </div>

  <!-- JS upgrade: divider comparison -->
  <div class="cmp-stage" aria-hidden="true">
    <div class="cmp-frame">
      <Image class="cmp-before" src={before} alt="" widths={[480, 800]} sizes="(max-width: 700px) 86vw, 400px" />
      <div class="cmp-after-clip">
        <Image class="cmp-after" src={after} alt="" widths={[480, 800]} sizes="(max-width: 700px) 86vw, 400px" />
      </div>
      <div class="cmp-divider"></div>
      {annotations.map((a) => (
        <span class="cmp-pin" style={`left:${a.x}%; top:${a.y}%;`}>{a.n}</span>
      ))}
      <span class="cmp-tag cmp-tag-before">{beforeLabel}</span>
      <span class="cmp-tag cmp-tag-after">{afterLabel}</span>
    </div>
    <input
      class="cmp-range"
      type="range"
      min="0"
      max="100"
      value="50"
      step="2"
      aria-label={`Comparison: ${beforeLabel} versus ${afterLabel}. Arrow keys move the divider.`}
    />
    <div class="cmp-controls">
      <button type="button" data-pos="0" aria-pressed="false">{beforeLabel}</button>
      <button type="button" data-pos="50" aria-pressed="true">Split</button>
      <button type="button" data-pos="100" aria-pressed="false">{afterLabel}</button>
    </div>
  </div>
</figure>

<script>
  const upgrade = () => {
    document.querySelectorAll<HTMLElement>('[data-compare]:not(.js)').forEach((root) => {
      root.classList.add('js');
      const range = root.querySelector<HTMLInputElement>('.cmp-range');
      const stage = root.querySelector<HTMLElement>('.cmp-stage');
      const buttons = [...root.querySelectorAll<HTMLButtonElement>('.cmp-controls button')];
      if (!range || !stage) return;
      stage.removeAttribute('aria-hidden');

      const apply = (v: number) => {
        root.style.setProperty('--pos', v + '%');
        range.value = String(v);
        range.setAttribute(
          'aria-valuetext',
          v <= 5 ? 'Showing before only' : v >= 95 ? 'Showing after only' : `Divider at ${v} percent`
        );
        buttons.forEach((b) => b.setAttribute('aria-pressed', String(Number(b.dataset.pos) === v)));
      };
      range.addEventListener('input', () => apply(Number(range.value)));
      buttons.forEach((b) => b.addEventListener('click', () => apply(Number(b.dataset.pos))));
      apply(50);
    });
  };
  upgrade();
  document.addEventListener('astro:page-load', upgrade);
</script>

<style>
  .cmp {
    margin: 0;
    --pos: 50%;
  }

  /* ---- fallback pair (default) ---- */
  .cmp-fallback {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
  }

  .cmp-fallback figure {
    margin: 0;
  }

  .cmp-fallback img {
    width: 100%;
    height: auto;
    border-radius: 14px;
  }

  .cmp-fallback figcaption {
    margin-top: 0.5rem;
    font: 600 max(0.72rem, 12px) / 1.4 var(--p-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--p-muted);
    text-align: center;
  }

  .cmp.js .cmp-fallback {
    display: none;
  }

  /* ---- upgraded stage ---- */
  .cmp-stage {
    display: none;
  }

  .cmp.js .cmp-stage {
    display: block;
  }

  .cmp-frame {
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
  }

  .cmp-frame img {
    display: block;
    width: 100%;
    height: auto;
  }

  .cmp-after-clip {
    position: absolute;
    inset: 0;
    clip-path: inset(0 0 0 var(--pos));
  }

  .cmp-divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--pos);
    width: 2px;
    background: var(--p-accent);
    transform: translateX(-1px);
    pointer-events: none;
  }

  .cmp-divider::after {
    content: '↔';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    background: var(--p-accent);
    color: var(--p-accent-ink);
    display: grid;
    place-items: center;
    font-size: 1rem;
  }

  .cmp-pin {
    position: absolute;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: var(--p-accent);
    color: var(--p-accent-ink);
    display: grid;
    place-items: center;
    font: 700 0.78rem/1 var(--p-mono);
    transform: translate(-50%, -50%);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
    pointer-events: none;
  }

  .cmp-tag {
    position: absolute;
    top: 0.8rem;
    font: 600 max(0.68rem, 12px) / 1 var(--p-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.35rem 0.6rem;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    pointer-events: none;
  }

  .cmp-tag-before {
    left: 0.8rem;
  }

  .cmp-tag-after {
    right: 0.8rem;
  }

  .cmp-range {
    width: 100%;
    margin-top: 0.9rem;
    accent-color: var(--p-accent);
  }

  .cmp-range:focus-visible {
    outline: 2px solid var(--p-accent);
    outline-offset: 3px;
  }

  .cmp-controls {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-top: 0.7rem;
  }

  .cmp-controls button {
    font: 600 max(0.72rem, 12px) / 1 var(--p-mono);
    letter-spacing: 0.06em;
    background: none;
    border: 1px solid var(--p-line);
    border-radius: 999px;
    color: var(--p-muted);
    padding: 0 0.95rem;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    cursor: pointer;
  }

  .cmp-controls button[aria-pressed='true'] {
    background: var(--p-accent);
    border-color: var(--p-accent);
    color: var(--p-accent-ink);
  }

  .cmp-controls button:focus-visible {
    outline: 2px solid var(--p-accent);
    outline-offset: 2px;
  }

  @media (max-width: 700px) {
    /* on small screens the toggle is primary; range stays for fine control */
    .cmp-divider::after {
      width: 2.6rem;
      height: 2.6rem;
    }
  }
</style>
