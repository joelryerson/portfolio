---
/**
 * EXPERIMENT · "Folded Atlas" · functional prototype.
 * Isolated route; nothing here touches production.
 *
 * One physical sheet, permanently divided into four printed panels
 * (Finderly NW, Asteri NE, StartupOS SW, ArtPärdē SE) around a visible
 * center spine and a scored horizontal crease. The overview shows the sheet
 * part-folded: each column tilts on the spine. Selecting a panel unfolds it
 * face-on along its fixed hinge while the grid reallocates (68/32 fr
 * transition), and the other three stay connected as tighter-folded margins,
 * still labeled and selectable. Direct switching refolds the active panel
 * while the new one opens — the sheet never separates.
 *
 * Mobile simplifies the geometry: flat 2×2 overview with drawn creases;
 * selecting unfolds the panel vertically (single rotateX) into a dominant
 * stage above a persistent mini-atlas whose positions never change.
 * ?p= deep links, history, reduced-motion instant states, no-JS linear.
 */
import homeLight from '../../assets/finderly/shots/home-light.webp';
import captureShot from '../../assets/finderly/shots/capture.webp';
import unitHifi from '../../assets/experiments/startupos-unit.webp';
import studiesStrip from '../../assets/experiments/artparde-studies.webp';
import logoFinal from '../../assets/artparde/logo-final.png';

const projects = [
  {
    id: 'finderly',
    no: '01',
    corner: 'nw',
    name: 'Finderly',
    year: '2026',
    cat: 'AI home repair',
    roles: 'Product design, UX/UI, and front-end implementation',
    desc: 'Rebuilt the home around starting a repair, with camera, video, and recent work available from one clear entry point.',
    href: '/work/finderly/',
    spot: '#d81fa4',
  },
  {
    id: 'asteri',
    no: '02',
    corner: 'ne',
    name: 'Asteri AI',
    year: '2026',
    cat: 'AI work platform',
    roles: 'Product design and design systems',
    desc: 'Consolidated a fragmented token foundation while preserving the product’s core table and preparing the homepage for migration.',
    href: '/work/asteri/',
    spot: '#3b5bdb',
  },
  {
    id: 'startupos',
    no: '03',
    corner: 'sw',
    name: 'StartupOS',
    year: '2022',
    cat: 'Founder education',
    roles: 'Product design',
    desc: 'Designed the reusable template system the team used to ship the MVP in five months.',
    href: '/work/startup-platform/',
    spot: '#5f3dc4',
  },
  {
    id: 'artparde',
    no: '04',
    corner: 'se',
    name: 'ArtPärdē',
    year: '2024',
    cat: 'Performing-arts nonprofit',
    roles: 'Brand and web design',
    desc: 'Created the identity and maintainable website the organization continues to run without me.',
    href: '/work/artparde/',
    spot: '#12b0a0',
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Folded Atlas · functional prototype — Joel Ryerson</title>
    <link rel="preload" href="/fonts/x/satoshi.woff2" as="font" type="font/woff2" crossorigin />
  </head>

  <body>
    <p class="ribbon" role="note">Experiment · “Folded Atlas” · functional prototype · not production</p>

    <div class="page" data-active="">
      <header class="top">
        <span class="who">Joel Ryerson</span>
        <span class="role">Product Designer &amp; Design Engineer</span>
        <nav class="links" aria-label="Site">
          <a href="#" aria-disabled="true">About</a>
          <a href="mailto:joelryerson@gmail.com">Contact</a>
        </nav>
      </header>

      <!-- mobile stage: the vertically unfolded face (hidden on desktop) -->
      <section class="mstage" aria-live="polite">
        {projects.map((p) => (
          <div class={`ms ms-${p.id}`}>
            <div class="ms-fold">
              <div class="ms-visual">
                {p.id === 'finderly' && (
                  <div class="finrow">
                    <div class="crop mphone" style={`background-image:url(${homeLight.src})`}></div>
                    <div class="crop mcam" style={`background-image:url(${captureShot.src})`}></div>
                  </div>
                )}
                {p.id === 'asteri' && (
                  <div class="astcol">
                    <div class="card"><span>Active studies</span><b>128</b><i>before · inline styles</i></div>
                    <div class="card"><span>Active studies</span><b>128</b><i>after · semantic tokens</i></div>
                  </div>
                )}
                {p.id === 'startupos' && <div class="crop mwide" style={`background-image:url(${unitHifi.src})`}></div>}
                {p.id === 'artparde' && (
                  <div class="aprow">
                    <div class="crop mmark" style={`background-image:url(${logoFinal.src})`}></div>
                    <div class="crop mband" style={`background-image:url(${studiesStrip.src})`}></div>
                  </div>
                )}
              </div>
              <div class="ms-info">
                <p class="i-name"><b>{p.name}</b> <span>{p.year} · {p.cat}</span></p>
                <p class="i-roles">{p.roles}</p>
                <p class="i-desc">{p.desc}</p>
                <a class="case" href={p.href}>Read case study<span aria-hidden="true"> →</span></a>
              </div>
            </div>
          </div>
        ))}
      </section>

      <!-- the sheet -->
      <main class="canvas" aria-label="Selected work">
        <div class="sheet" id="sheet" data-active="">
          <span class="cropmark cm-tl" aria-hidden="true"></span>
          <span class="cropmark cm-tr" aria-hidden="true"></span>
          <span class="cropmark cm-bl" aria-hidden="true"></span>
          <span class="cropmark cm-br" aria-hidden="true"></span>
          <span class="plate" aria-hidden="true">JR · four projects · folded</span>

          {projects.map((p) => (
            <section class={`panel p-${p.corner}`} data-p={p.id} aria-label={p.name}>
              <div class="face">
                <header class="plabel">
                  <span class="stamp" style={`background:${p.spot}`}>{p.no}</span>
                  <b>{p.name}</b>
                  <span class="pmeta">{p.year} · {p.cat}</span>
                  <i class="aff" aria-hidden="true">→</i>
                </header>

                <div class="pvis">
                  {p.id === 'finderly' && <div class="crop v-fin" style={`background-image:url(${homeLight.src})`}></div>}
                  {p.id === 'asteri' && (
                    <div class="v-ast">
                      <div class="card"><span>Active studies</span><b>128</b><i class="only-act">after · semantic tokens</i></div>
                      <div class="card only-act"><span>Active studies</span><b>128</b><i>after · semantic tokens</i></div>
                    </div>
                  )}
                  {p.id === 'startupos' && <div class="crop v-sos" style={`background-image:url(${unitHifi.src})`}></div>}
                  {p.id === 'artparde' && (
                    <div class="v-ap">
                      <div class="crop v-mark" style={`background-image:url(${logoFinal.src})`}></div>
                      <div class="crop v-band only-act" style={`background-image:url(${studiesStrip.src})`}></div>
                    </div>
                  )}
                  {p.id === 'finderly' && <div class="crop v-cam only-act" style={`background-image:url(${captureShot.src})`}></div>}
                </div>

                <div class="pinfo">
                  <p class="i-roles">{p.roles}</p>
                  <p class="i-desc">{p.desc}</p>
                  <a class="case" href={p.href}>Read case study<span aria-hidden="true"> →</span></a>
                </div>
              </div>

              <button
                class="hit"
                type="button"
                data-select={p.id}
                aria-pressed="false"
                aria-label={`Unfold ${p.name} (${p.year}, ${p.cat})`}
              ></button>
            </section>
          ))}
        </div>
      </main>
    </div>

    <script is:inline>
      (() => {
        const root = document.documentElement;
        root.classList.add('js');
        const page = document.querySelector('.page');
        const sheet = document.getElementById('sheet');
        const hits = [...document.querySelectorAll('[data-select]')];
        const IDS = ['finderly', 'asteri', 'startupos', 'artparde'];

        const apply = (id) => {
          const active = IDS.includes(id) ? id : '';
          sheet.dataset.active = active;
          page.dataset.active = active;
          hits.forEach((h) => h.setAttribute('aria-pressed', String(h.dataset.select === active)));
        };

        const select = (id, push = true) => {
          if (sheet.dataset.active === id) return;
          apply(id);
          if (push) history.pushState({ p: id }, '', id ? '?p=' + id : location.pathname);
        };

        sheet.addEventListener('click', (e) => {
          const btn = e.target.closest('[data-select]');
          if (btn) select(btn.dataset.select);
        });

        window.addEventListener('popstate', (e) => {
          apply(e.state?.p ?? new URLSearchParams(location.search).get('p') ?? '');
        });

        apply(new URLSearchParams(location.search).get('p') || '');
        history.replaceState({ p: sheet.dataset.active }, '', location.href);
      })();
    </script>

    <style>
      @font-face {
        font-family: 'Satoshi X';
        src: url('/fonts/x/satoshi.woff2') format('woff2');
        font-weight: 300 900;
        font-display: swap;
      }
      :root {
        --shell: #eceadf;
        --paper: #f7f5ec;
        --ink: #141311;
        --mute: #6e6a60;
        --line: #c8c4b4;
        --signal: #e94a10;
        --dur: 750ms;
        --ease: cubic-bezier(0.32, 0.72, 0.05, 1);
        color-scheme: light;
      }
      * { box-sizing: border-box; }
      html, body { height: 100%; }
      body {
        margin: 0;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        background: var(--shell);
        color: var(--ink);
        font-family: 'Satoshi X', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .ribbon {
        margin: 0;
        padding: 0.4rem 1.2rem;
        background: var(--ink);
        color: var(--paper);
        font-size: max(0.8rem, 13px);
        font-weight: 500;
        text-align: center;
      }
      .page { flex: 1; min-height: 0; display: flex; flex-direction: column; }
      .page * { margin: 0; }

      .top {
        height: 64px;
        flex: none;
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 0 clamp(16px, 2.5vw, 32px);
        border-bottom: 1px solid var(--line);
      }
      .who { font-size: 16px; font-weight: 800; letter-spacing: -0.01em; white-space: nowrap; }
      .role { font-size: 13.5px; font-weight: 500; color: var(--mute); }
      .links { margin-left: auto; display: flex; gap: 18px; }
      .links a { font-size: 14px; font-weight: 650; color: var(--ink); text-decoration: none; padding: 8px 0; }
      .links a:hover { color: var(--signal); }
      .links a:last-child { border-bottom: 2px solid var(--signal); padding-bottom: 2px; }
      .links a:focus-visible { outline: 2px solid var(--signal); outline-offset: 3px; }

      /* ---------- the sheet on the table ---------- */
      .canvas {
        flex: 1;
        min-height: 460px;
        display: grid;
        place-items: center;
        padding: clamp(14px, 3vh, 34px) clamp(14px, 3vw, 40px);
      }
      .sheet {
        position: relative;
        width: min(100%, 1220px);
        height: min(100%, 720px);
        min-height: 430px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 1fr 1fr;
        border: 2px solid var(--ink);
        background: #e9e4d2; /* the sheet's reverse, visible in the fold gaps */
        box-shadow: 8px 8px 0 rgba(20, 19, 17, 0.16);
        transition: grid-template-columns var(--dur) var(--ease), grid-template-rows var(--dur) var(--ease);
      }
      .sheet[data-active='finderly'] { grid-template-columns: 68fr 32fr; grid-template-rows: 68fr 32fr; }
      .sheet[data-active='asteri'] { grid-template-columns: 32fr 68fr; grid-template-rows: 68fr 32fr; }
      .sheet[data-active='startupos'] { grid-template-columns: 68fr 32fr; grid-template-rows: 32fr 68fr; }
      .sheet[data-active='artparde'] { grid-template-columns: 32fr 68fr; grid-template-rows: 32fr 68fr; }

      /* print chrome */
      .cropmark { position: absolute; width: 18px; height: 18px; border-color: var(--ink); border-style: solid; border-width: 0; z-index: 6; }
      .cm-tl { left: -26px; top: -26px; border-right-width: 1.5px; border-bottom-width: 1.5px; }
      .cm-tr { right: -26px; top: -26px; border-left-width: 1.5px; border-bottom-width: 1.5px; }
      .cm-bl { left: -26px; bottom: -26px; border-right-width: 1.5px; border-top-width: 1.5px; }
      .cm-br { right: -26px; bottom: -26px; border-left-width: 1.5px; border-top-width: 1.5px; }
      .plate {
        position: absolute;
        left: 50%;
        top: -24px;
        transform: translateX(-50%);
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--mute);
        z-index: 6;
        white-space: nowrap;
      }

      /* ---------- panels ---------- */
      .panel { position: relative; min-width: 0; min-height: 0; perspective: 1300px; }
      .sheet[data-active='finderly'] .p-nw,
      .sheet[data-active='asteri'] .p-ne,
      .sheet[data-active='startupos'] .p-sw,
      .sheet[data-active='artparde'] .p-se { z-index: 2; }
      /* the visible creases: spine + scored horizontal fold */
      .p-nw, .p-sw { border-right: 1.5px dashed color-mix(in srgb, var(--ink) 55%, transparent); }
      .p-nw, .p-ne { border-bottom: 1.5px solid color-mix(in srgb, var(--ink) 30%, transparent); }

      .face {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        padding: clamp(10px, 1.6vw, 20px);
        background:
          linear-gradient(to right, rgba(20, 19, 17, 0.05), transparent 14%),
          var(--paper);
        transition: transform var(--dur) var(--ease);
        overflow: hidden;
      }
      /* hinges live on the spine */
      .p-nw .face, .p-sw .face { transform-origin: 100% 50%; }
      .p-ne .face, .p-se .face {
        transform-origin: 0% 50%;
        background:
          linear-gradient(to left, rgba(20, 19, 17, 0.05), transparent 14%),
          var(--paper);
      }

      /* folded overview */
      .js .sheet[data-active=''] .p-nw .face, .js .sheet[data-active=''] .p-sw .face { transform: rotateY(-13deg); }
      .js .sheet[data-active=''] .p-ne .face, .js .sheet[data-active=''] .p-se .face { transform: rotateY(13deg); }
      /* unfolded active + tighter margins */
      .js .sheet[data-active]:not([data-active='']) .p-nw .face,
      .js .sheet[data-active]:not([data-active='']) .p-sw .face { transform: rotateY(-24deg); }
      .js .sheet[data-active]:not([data-active='']) .p-ne .face,
      .js .sheet[data-active]:not([data-active='']) .p-se .face { transform: rotateY(24deg); }
      .js .sheet[data-active='finderly'] .p-nw[data-p='finderly'] .face,
      .js .sheet[data-active='asteri'] .p-ne[data-p='asteri'] .face,
      .js .sheet[data-active='startupos'] .p-sw[data-p='startupos'] .face,
      .js .sheet[data-active='artparde'] .p-se[data-p='artparde'] .face { transform: rotateY(0deg); }

      /* ---------- panel content ---------- */
      .plabel { display: flex; align-items: baseline; gap: 8px; flex: none; z-index: 2; }
      .stamp {
        align-self: center;
        color: #fff;
        font-size: 10.5px;
        font-weight: 800;
        padding: 3px 6px;
        letter-spacing: 0.06em;
      }
      .plabel b { font-size: clamp(15px, 1.5vw, 20px); font-weight: 800; letter-spacing: -0.01em; white-space: nowrap; }
      .pmeta { font-size: 11.5px; color: var(--mute); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .aff { margin-left: auto; font-style: normal; font-weight: 800; color: var(--mute); }
      .panel:hover .aff { color: var(--signal); }

      .pvis { flex: 1 1 0; min-height: 0; margin-top: 8px; position: relative; }
      .crop { background-repeat: no-repeat; background-size: cover; }
      .v-fin { position: absolute; inset: 0; background-position: 50% 12%; border: 1px solid var(--line); }
      .v-cam { position: absolute; right: 4%; top: 6%; bottom: 24%; width: 26%; background-position: 50% 30%; border: 1px solid var(--line); opacity: 0; transition: opacity 0.3s; }
      .v-sos { position: absolute; inset: 0; background-size: 135% auto; background-position: 15% 0; border: 1px solid var(--line); }
      .v-ast { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; gap: 22px; }
      .v-ap { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; gap: 16px; }
      .v-mark { height: min(84%, 300px); aspect-ratio: 1; background-position: 50% 50%; flex: none; }
      .v-band { width: 30%; height: 84%; background-size: 100% auto; background-repeat: repeat-y; background-color: #141414; opacity: 0; transition: opacity 0.3s; display: none; }

      .card {
        background: #f7f8fa;
        border: 1px solid #e2e4e9;
        border-radius: 10px;
        padding: clamp(12px, 1.2vw, 20px);
        width: min(240px, 42%);
      }
      .card span { display: block; font-size: clamp(11px, 0.9vw, 13.5px); color: #6b7280; }
      .card b { display: block; font-size: clamp(18px, 1.9vw, 27px); font-weight: 650; color: #111827; margin-top: 2px; }
      .card i { display: block; font-style: normal; font-size: clamp(10px, 0.8vw, 12px); color: var(--mute); margin-top: 10px; }
      .v-ast .card.only-act { display: none; }
      .v-ast .card .only-act { visibility: hidden; }

      /* extras that appear only on the unfolded face */
      .js .sheet[data-active='finderly'] .p-nw .v-cam { opacity: 1; }
      .js .sheet[data-active='finderly'] .p-nw .v-fin { right: 34%; }
      .v-fin { transition: right var(--dur) var(--ease); right: 0; position: absolute; }
      .js .sheet[data-active='asteri'] .p-ne .v-ast .card.only-act { display: block; }
      .js .sheet[data-active='asteri'] .p-ne .v-ast .card .only-act,
      .js .sheet[data-active='asteri'] .p-ne .card .only-act { visibility: visible; }
      .js .sheet[data-active='artparde'] .p-se .v-band { display: block; opacity: 1; }

      .pinfo {
        flex: none;
        padding-top: 10px;
        max-width: 58ch;
        opacity: 0;
        visibility: hidden;
        height: 0;
        overflow: hidden;
        transition: opacity 260ms ease, visibility 0s 260ms;
        z-index: 3;
      }
      .js .sheet[data-active='finderly'] .p-nw .pinfo,
      .js .sheet[data-active='asteri'] .p-ne .pinfo,
      .js .sheet[data-active='startupos'] .p-sw .pinfo,
      .js .sheet[data-active='artparde'] .p-se .pinfo {
        opacity: 1;
        visibility: visible;
        height: auto;
        overflow: visible;
        transition: opacity 300ms ease 260ms, visibility 0s;
      }
      .i-roles { font-size: 12px; color: var(--mute); }
      .i-desc { font-size: 14px; line-height: 1.45; margin-top: 4px; }
      .case {
        display: inline-block;
        margin-top: 8px;
        font-size: 13.5px;
        font-weight: 700;
        color: var(--ink);
        text-decoration: none;
        border-bottom: 2px solid var(--signal);
        padding-bottom: 2px;
        position: relative;
        z-index: 4;
      }
      .case:hover { color: var(--signal); }
      .case:focus-visible { outline: 2px solid var(--signal); outline-offset: 3px; }

      .hit {
        position: absolute;
        inset: 0;
        z-index: 5;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
      }
      .hit[aria-pressed='true'] { cursor: default; }
      .hit:focus-visible { outline: 3px solid var(--signal); outline-offset: -3px; }

      .mstage { display: none; }

      /* ---------- reduced motion ---------- */
      @media (prefers-reduced-motion: reduce) {
        .sheet, .face, .pinfo, .v-fin, .v-cam, .v-band, .ms-fold { transition: none !important; }
      }

      /* ---------- no-JS: flat readable sheet ---------- */
      html:not(.js) .face { position: relative; transform: none; }
      html:not(.js) .sheet { display: block; height: auto; }
      html:not(.js) .panel { border: none; border-top: 1.5px solid var(--line); min-height: 520px; }
      html:not(.js) .pvis { min-height: 340px; }
      html:not(.js) .pinfo { opacity: 1; visibility: visible; height: auto; overflow: visible; }
      html:not(.js) .hit { display: none; }
      html:not(.js) .v-cam { opacity: 1; }
      html:not(.js) .v-band { display: block; opacity: 1; }
      html:not(.js) .v-ast .card.only-act { display: block; }
      html:not(.js) .v-ast .card .only-act { visibility: visible; }

      /* ---------- mobile: simplified fold ---------- */
      @media (max-width: 760px) {
        .role { display: none; }
        .top { height: 56px; }
        .canvas { perspective: 1000px; padding: 10px 12px; }
        .sheet { min-height: 0; box-shadow: 5px 5px 0 rgba(20, 19, 17, 0.16); }
        .cropmark, .plate { display: none; }

        /* overview: flat sheet with drawn creases */
        .js .sheet[data-active=''] .face { transform: none !important; }
        .plabel { flex-wrap: wrap; row-gap: 2px; }
        .plabel b { font-size: 14px; }
        .pmeta { font-size: 10.5px; width: 100%; order: 3; }
        .aff { position: absolute; right: 10px; top: 10px; }

        /* selected: stage above, sheet compresses to a mini-atlas */
        .mstage { flex: 1; min-height: 0; position: relative; display: none; }
        .page[data-active]:not([data-active='']) .mstage { display: block; }
        .ms { position: absolute; inset: 0; display: none; }
        .page[data-active='finderly'] .ms-finderly,
        .page[data-active='asteri'] .ms-asteri,
        .page[data-active='startupos'] .ms-startupos,
        .page[data-active='artparde'] .ms-artparde { display: block; }
        .ms-fold {
          position: absolute;
          inset: 0;
          display: flex;
          flex-direction: column;
          transform-origin: 50% 100%;
          transform: rotateX(0deg);
        }
        .page[data-active]:not([data-active='']) .ms-fold { animation: munfold var(--dur) var(--ease); }
        @keyframes munfold {
          from { transform: rotateX(-7deg); opacity: 0.6; }
          to { transform: rotateX(0); opacity: 1; }
        }
        .ms-visual { flex: 1 1 0; min-height: 0; position: relative; margin: 10px 14px 0; }
        .finrow { position: absolute; inset: 0; display: flex; gap: 10px; justify-content: center; }
        .mphone { width: 58%; background-size: cover; background-position: 50% 10%; border: 1px solid var(--line); }
        .mcam { width: 26%; height: 62%; align-self: flex-start; margin-top: 6%; background-size: cover; background-position: 50% 30%; border: 1px solid var(--line); }
        .astcol { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: center; gap: 12px; align-items: center; }
        .astcol .card { width: min(84%, 260px); }
