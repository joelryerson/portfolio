---
import PortfolioAIWorkspace from '../../components/experiments/PortfolioAIWorkspace.astro';
/**
 * EXPERIMENT · "Project Field — Clean" · subtraction test.
 * Same architecture as /experiments/project-field with every visual
 * composition removed: purely typographic and structural. Answers one
 * question: does the expanding four-region field feel confident, clean,
 * distinctive, and premium without the imagery?
 * Isolated route; nothing here touches production.
 */
const projects = [
  {
    id: 'finderly',
    name: 'Finderly',
    year: '2026',
    catShort: 'AI home repair',
    cat: 'AI-guided home repair',
    roles: 'Product design, UX/UI, and front-end implementation',
    desc: 'Rebuilt the home around starting a repair, with camera, video, and recent work available from one clear entry point.',
    href: '/work/finderly/',
  },
  {
    id: 'asteri',
    name: 'Asteri AI',
    year: '2026',
    catShort: 'AI work platform',
    cat: 'AI work platform',
    roles: 'Product design and design systems',
    desc: 'Consolidated a fragmented token foundation while preserving the product’s core table and preparing the homepage for migration.',
    href: '/work/asteri/',
  },
  {
    id: 'startupos',
    name: 'StartupOS',
    year: '2022',
    catShort: 'Founder education',
    cat: 'Founder education platform',
    roles: 'Product design',
    desc: 'Designed the reusable template system the team used to ship the MVP in five months.',
    href: '/work/startup-platform/',
  },
  {
    id: 'artparde',
    name: 'ArtPärdē',
    year: '2024',
    catShort: 'Performing-arts nonprofit',
    cat: 'Performing-arts nonprofit',
    roles: 'Brand and web design',
    desc: 'Created the identity and maintainable website the organization continues to run without me.',
    href: '/work/artparde/',
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Project Field · clean · AI variant — Joel Ryerson</title>
    <link rel="preload" href="/fonts/x/satoshi.woff2" as="font" type="font/woff2" crossorigin />
  </head>

  <body>
    <p class="ribbon" role="note">Experiment · “Project Field — Clean” · AI workspace variant · not production</p>

    <header class="top">
      <span class="who">Joel Ryerson</span>
      <span class="role-line">Product Designer &amp; Design Engineer</span>
      <span class="pos">Product design, systems, and front-end execution.</span>
      <nav class="nav" aria-label="Site">
        <a href="#field">Work</a>
        <a href="#" aria-disabled="true">About</a>
        <a href="mailto:joelryerson@gmail.com">Contact</a>
      </nav>
    </header>

    <main class="field" id="field" aria-label="Selected work">
      {projects.map((p, i) => (
        <section
          class={`region ${i === 0 ? 'active' : ''}`}
          id={`p-${p.id}`}
          data-p={p.id}
          aria-label={p.name}
        >
          <h2 class="name">{p.name}</h2>

          <p class="cmeta">
            <b>{p.year}</b>
            <span>{p.catShort}</span>
          </p>

          <div class="detail">
            <p class="spec"><b>{p.year}</b> · {p.cat}</p>
            <hr class="rule" />
            <div class="grp">
              <p class="statement">{p.desc}</p>
              <p class="roles">{p.roles}</p>
            </div>
            <a class="case" href={p.href}>Read case study<span aria-hidden="true"> →</span></a>
          </div>

          <a
            class="hit"
            href={`?p=${p.id}`}
            data-select={p.id}
            aria-expanded={i === 0 ? 'true' : 'false'}
            aria-controls={`p-${p.id}`}
            aria-label={`View ${p.name} (${p.year}, ${p.catShort})`}
          ></a>
        </section>
      ))}
    </main>

    <script is:inline>
      (() => {
        const root = document.documentElement;
        root.classList.add('js');
        const regions = [...document.querySelectorAll('.region')];
        const hits = [...document.querySelectorAll('[data-select]')];
        const ids = regions.map((r) => r.dataset.p);
        const pawListeners = [];
        window.PAW_HOST = {
          route: 'project-field-clean',
          getProject: () => { const r = document.querySelector('.region.active'); return r ? r.dataset.p : ''; },
          setProject: (id) => activate(id, true),
          onChange: (cb) => pawListeners.push(cb),
          minHostWidth: 1060,
          caps: { follow: true, here: true, instrument: false },
          // physical region of a project's column, inset below the name block
          region: (id) => {
            const pid = id || (document.querySelector('.region.active') || {}).dataset?.p;
            if (!pid) return null;
            const el = document.querySelector('.region[data-p="' + pid + '"]');
            if (!el) return null;
            const b = el.getBoundingClientRect();
            return { left: b.left + 12, right: b.right - 12, top: b.top + 96, bottom: b.bottom - 12, width: b.width - 24, height: b.height - 108 };
          },
          // measured defaults: live inside the active region's negative space
          // (right side, below the name, above the field's bottom edge) —
          // overlay rather than compress the field
          defaults: (vp, pillSz) => {
            const a = document.querySelector('.region.active');
            const b = a ? a.getBoundingClientRect() : null;
            const minimized = b
              ? { x: b.right - pillSz.w - 24, y: Math.min(vp.h - pillSz.h - 20, b.bottom - pillSz.h - 20) }
              : { corner: 'br' };
            const expanded = b && vp.w >= 1000
              ? { kind: 'float', x: Math.max(20, b.right - 428), y: Math.max(96, Math.min(b.bottom - 584, vp.h - 600)) }
              : { kind: 'snap', zone: 'br' };
            return { minimized, expanded };
          },
          reserve: (m) => {
            document.body.classList.toggle('paw-res-left', m === 'left');
            document.body.classList.toggle('paw-res-right', m === 'right');
          },
        };


        const activate = (id, push) => {
          const cur = document.querySelector('.region.active');
          const prev = cur ? cur.dataset.p : '';
          regions.forEach((r) => r.classList.toggle('active', r.dataset.p === id));
          hits.forEach((h) => h.setAttribute('aria-expanded', String(h.dataset.select === id)));
          if (push && prev !== id) history.pushState({ p: id }, '', '?p=' + id);
          pawListeners.forEach((f) => f(id));
        };

        hits.forEach((h) => {
          h.addEventListener('click', (e) => {
            e.preventDefault();
            activate(h.dataset.select, true);
          });
        });

        window.addEventListener('popstate', (e) => {
          const q = e.state?.p ?? new URLSearchParams(location.search).get('p');
          activate(ids.includes(q) ? q : 'finderly', false);
        });
        const wanted = new URLSearchParams(location.search).get('p');
        const initial = ids.includes(wanted) ? wanted : 'finderly';
        activate(initial, false);
        history.replaceState({ p: initial }, '', '?p=' + initial);
      })();
    </script>

    <style>
      @font-face {
        font-family: 'Satoshi X';
        src: url('/fonts/x/satoshi.woff2') format('woff2');
        font-weight: 300 900;
        font-display: swap;
      }

      :root {
        --shell: #f2f0eb;
        --dim: #eae7e0;
        --ink: #141311;
        --mute: #6e6a60;
        --line: #cdcabf;
        --signal: #e94a10;
        --dur: 560ms;
        --ease: cubic-bezier(0.32, 0.72, 0.05, 1);
        color-scheme: light;
      }
      * { box-sizing: border-box; }

      html, body { height: 100%; }
      body {
        margin: 0;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        background: var(--shell);
        color: var(--ink);
        font-family: 'Satoshi X', system-ui, sans-serif;
        font-size: max(1rem, 16px);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }

      .ribbon {
        margin: 0;
        padding: 0.5rem 1.2rem;
        background: var(--ink);
        color: var(--shell);
        font-size: max(0.8rem, 13px);
        font-weight: 500;
        text-align: center;
      }

      /* ---------- header ---------- */
      .top {
        height: 80px;
        display: flex;
        align-items: center;
        gap: 1.6rem;
        padding: 0 clamp(1rem, 2.5vw, 2rem);
        border-bottom: 1px solid var(--line);
      }
      .who { font-size: 17px; font-weight: 800; letter-spacing: -0.01em; white-space: nowrap; }
      .role-line { font-size: 14px; font-weight: 550; color: var(--mute); white-space: nowrap; }
      .pos { font-size: 14px; color: var(--mute); margin-left: auto; }
      .nav { display: flex; gap: 1.3rem; }
      .nav a {
        font-size: 14.5px;
        font-weight: 650;
        color: var(--ink);
        text-decoration: none;
        padding: 0.6rem 0;
      }
      .nav a:hover { color: var(--signal); }
      .nav a:last-child { border-bottom: 2px solid var(--signal); padding-bottom: 2px; }
      .nav a:focus-visible { outline: 2px solid var(--signal); outline-offset: 3px; }

      /* ---------- the field ---------- */
      .field {
        display: flex;
        flex: 1;
        min-height: 480px;
      }
      .region {
        position: relative;
        min-width: 0;
        overflow: hidden;
        flex: 1 1 0;
        background: var(--dim);
        transition: flex-grow var(--dur) var(--ease), background-color 0.35s ease;
      }
      .js .region.active { flex-grow: 4.143; background: var(--shell); } /* 58% / 14% ×3 */
      .region + .region { border-left: 1px solid var(--line); }
      .js .region:not(.active):hover { background: #efece5; }

      .name {
        position: absolute;
        top: 26px;
        left: 26px;
        z-index: 3;
        margin: 0;
        font-size: clamp(40px, 4.6vw, 66px);
        font-weight: 800;
        letter-spacing: -0.025em;
        line-height: 1;
        white-space: nowrap;
        transform: scale(0.42);
        transform-origin: top left;
        transition: transform var(--dur) var(--ease);
      }
      .js .region.active .name { transform: scale(1); }

      /* collapsed meta: pinned to the bottom, two stacked lines */
      .cmeta {
        position: absolute;
        left: 26px;
        bottom: 24px;
        z-index: 3;
        margin: 0;
        font-size: 13.5px;
        line-height: 1.5;
        color: var(--mute);
        transition: opacity 0.3s;
      }
      .cmeta b { display: block; color: var(--ink); font-weight: 750; }
      .cmeta span { display: block; }
      .js .region.active .cmeta { opacity: 0; }

      .hit { position: absolute; inset: 0; z-index: 5; }
      .js .region.active .hit { display: none; }
      .hit:focus-visible { outline: 3px solid var(--signal); outline-offset: -3px; }

      /* ---------- active detail: the typographic composition ---------- */
      .detail {
        position: absolute;
        inset: 128px 30px 30px 26px;
        display: flex;
        flex-direction: column;
        z-index: 2;
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 0.28s ease, transform 0.45s var(--ease);
        pointer-events: none;
      }
      .js .region.active .detail {
        opacity: 1;
        transform: none;
        transition-delay: 0.2s;
        pointer-events: auto;
      }
      .spec { margin: 0; font-size: 14.5px; color: var(--mute); }
      .spec b { color: var(--ink); font-weight: 750; }
      .rule { border: none; border-top: 1px solid var(--line); margin: 16px 0 0; width: 100%; }

      .grp { margin: auto 0; padding-left: 11%; }
      .statement {
        margin: 0;
        font-size: clamp(21px, 2.15vw, 30px);
        line-height: 1.38;
        font-weight: 520;
        letter-spacing: -0.012em;
        max-width: 24ch;
        text-wrap: balance;
      }
      .roles { margin: 18px 0 0; font-size: 14px; color: var(--mute); }

      .case {
        align-self: flex-start;
        font-size: 15px;
        font-weight: 700;
        color: var(--ink);
        text-decoration: none;
        border-bottom: 2px solid var(--signal);
        padding-bottom: 2px;
      }
      .case:hover { color: var(--signal); }
      .case:focus-visible { outline: 2px solid var(--signal); outline-offset: 3px; }

      /* ---------- reduced motion ---------- */
      @media (prefers-reduced-motion: reduce) {
        .region, .name, .detail, .cmeta { transition: none !important; }
      }

      /* ---------- no-JS: linear sequence ---------- */
      html:not(.js) .field { flex-direction: column; }
      html:not(.js) .region { min-height: 60vh; background: var(--shell); }
      html:not(.js) .region + .region { border-left: none; border-top: 1px solid var(--line); }
      html:not(.js) .name { transform: scale(1); }
      html:not(.js) .detail { opacity: 1; transform: none; pointer-events: auto; }
      html:not(.js) .cmeta { opacity: 0; }
      html:not(.js) .hit { display: none; }

      /* ---------- mobile: the field rotated ---------- */
      @media (max-width: 760px) {
        .top { height: 64px; gap: 0.9rem; }
        .pos, .role-line { display: none; }
        .nav { margin-left: auto; gap: 1rem; }

        .field { flex-direction: column; min-height: 520px; }
        .region { flex: 0.0001 1 60px; }
        .js .region.active { flex-grow: 1; }
        .region + .region { border-left: none; border-top: 1px solid var(--line); }

        .name {
          top: 30px;
          left: 20px;
          font-size: 38px;
          transform: translateY(-50%) scale(0.55);
        }
        .js .region.active .name { top: 18px; transform: translateY(0) scale(1); }

        .cmeta {
          left: auto;
          right: 20px;
          bottom: auto;
          top: 30px;
          transform: translateY(-50%);
          text-align: right;
          font-size: 12.5px;
        }
        .cmeta b { display: inline; }
        .cmeta span { display: inline; }
        .cmeta span::before { content: ' · '; }

        .detail { inset: 78px 20px 20px 20px; }
        .grp { padding-left: 6%; }
        .statement { font-size: clamp(18px, 5vw, 22px); max-width: none; }
        .roles { font-size: 13px; margin-top: 12px; }
      }
      @media (max-width: 760px) and (max-height: 700px) {
        .detail { inset: 68px 20px 16px 20px; }
        .statement { font-size: 17px; line-height: 1.42; }
        .roles { font-size: 12px; margin-top: 10px; }
        .rule { margin-top: 10px; }
      }
    
      /* ---------- AI workspace integration ---------- */
      :root {
        --paw-bg: #fbfaf8;
        --paw-bg2: #f0ede6;
        --paw-ink: #141311;
        --paw-mute: #6e6a60;
        --paw-line: #cdcabf;
        --paw-accent: #e94a10;
        --paw-radius: 0px;
      }
      body.paw-res-left .field { margin-left: 436px; }
      body.paw-res-right .field { margin-right: 436px; }

    </style>
    <PortfolioAIWorkspace />
  </body>
</html>
