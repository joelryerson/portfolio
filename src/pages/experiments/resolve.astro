---
/**
 * EXPERIMENT · "Resolve" · single homepage concept
 * Isolated route. Standalone shell; nothing here touches production.
 *
 * Central idea: a highly designed project index with one central living stage.
 * The four project titles ARE the navigation. One project is active at a time;
 * switching makes the stage recompose: the outgoing composition loosens, the
 * incoming fragments settle into place, the decision statement and case link
 * follow, the page identity stays put. Complexity resolving into clarity.
 *
 * No-JS default: the four plates render as a calm linear index and the rail
 * anchors jump to them. JS upgrades the plates into one stacked living stage.
 * Reduced motion: instant swaps, nothing animates.
 */
import { Image } from 'astro:assets';

import homeLight from '../../assets/finderly/shots/home-light.webp';
import captureShot from '../../assets/finderly/shots/capture.webp';
import unitShot from '../../assets/experiments/startupos-unit.webp';
import wizardShot from '../../assets/experiments/startupos-wizard.webp';
import logoFinal from '../../assets/artparde/logo-final.png';
import studiesStrip from '../../assets/experiments/artparde-studies.webp';

const projects = [
  {
    id: 'finderly',
    no: '01',
    title: 'Finderly',
    short: 'AI home-repair app · 2026',
    meta: 'Design Engineer · AI Vision Technologies · iOS, Android, web',
    decision:
      'Every AI product opens on a text box. Finderly’s problems are physical, so the home was rebuilt around the camera: a month-long overhaul, 303 files, and navigation that stopped lying.',
    href: '/work/finderly/',
    chip: 'Shipped July 2026',
  },
  {
    id: 'asteri',
    no: '02',
    title: 'Asteri AI',
    short: 'Work-intelligence platform · 2026',
    meta: 'Design Engineer · seed-stage startup · six-week engagement',
    decision:
      'The audit found systemic UI inconsistency. Token infrastructure came first, appearance unchanged on purpose: the company’s first design system in production, rolling on after the engagement ended.',
    href: '/work/asteri/',
    chip: 'Identical on purpose',
  },
  {
    id: 'startupos',
    no: '03',
    title: 'StartupOS',
    short: 'Founder-education platform · 2022',
    meta: 'Product Designer · every surface, copy included',
    decision:
      'Bespoke lesson designs would have eaten the five-month clock. One reusable template, five iterations deep, turned executive churn into a non-event. The MVP shipped; Demo Day validated it.',
    href: '/work/startup-platform/',
    chip: 'MVP in five months',
  },
  {
    id: 'artparde',
    no: '04',
    title: 'ArtPärdē',
    short: 'Performing-arts non-profit · 2024, ongoing',
    meta: 'Brand & web · San Francisco 501(c)(3)',
    decision:
      'A volunteer-run non-profit doesn’t need custom code, it needs a site volunteers can run. The craft budget went to the brand instead. Two years on, nothing has needed rescuing.',
    href: '/work/artparde/',
    chip: 'Still their home, two years on',
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Resolve · homepage concept — Joel Ryerson</title>
    <link rel="preload" href="/fonts/x/gambetta.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/x/switzer.woff2" as="font" type="font/woff2" crossorigin />
  </head>

  <body>
    <p class="ribbon" role="note">Experiment · “Resolve” · homepage concept · not production</p>

    <div class="shell">
      <header class="top">
        <span class="wordmark">Joel Ryerson</span>
        <span class="role">Product designer &amp; design engineer</span>
        <a class="contact" href="mailto:joelryerson@gmail.com">Contact</a>
      </header>

      <main class="board">
        <!-- ============ INTRO + RAIL ============ -->
        <div class="left">
          <section class="intro">
            <h1>
              The mock gets approved.<br />
              The build ships.<br />
              <em>I close the gap between them.</em>
            </h1>
            <p class="value">
              Product, UX, and UI decisions, carried all the way into production.
              East Bay, CA · available July 2026.
            </p>
          </section>

          <nav class="railwrap" aria-label="Projects">
            <p class="rail-label">Selected work, 2022–2026</p>
            <ol class="rail">
              {projects.map((p, i) => (
                <li>
                  <a
                    class="rail-item"
                    href={`#p-${p.id}`}
                    data-p={p.id}
                    aria-current={i === 0 ? 'true' : undefined}
                  >
                    <span class="no">{p.no}</span>
                    <span class="t">{p.title}</span>
                    <span class="d">{p.short}</span>
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </div>

        <!-- ============ THE STAGE ============ -->
        <div class="stage" id="stage">
          <!-- FINDERLY -->
          <section class="plate p-finderly" id="p-finderly" data-p="finderly" aria-label="Finderly">
            <div class="comp">
              <div class="frag f2 shot capture">
                <Image src={captureShot} alt="Finderly camera in ordered multi-capture mode with a running photo count" widths={[300, 480]} sizes="180px" />
              </div>
              <div class="frag f1 shot main">
                <Image src={homeLight} alt="Finderly home screen: capture hero asking What needs fixing, recent projects rail, honest navigation dock" widths={[420, 680]} sizes="(max-width: 940px) 52vw, 300px" />
              </div>
              <span class="frag f3 chip">Shipped July 2026</span>
            </div>
            <div class="detail">
              <p class="decision">
                Every AI product opens on a text box. Finderly’s problems are physical, so the home
                was rebuilt around the camera: a month-long overhaul, 303 files, and navigation
                that stopped lying.
              </p>
              <p class="meta">Design Engineer · AI Vision Technologies · iOS, Android, web</p>
              <a class="case" href="/work/finderly/">Read the Finderly case study<span aria-hidden="true"> →</span></a>
            </div>
          </section>

          <!-- ASTERI -->
          <section class="plate p-asteri" id="p-asteri" data-p="asteri" aria-label="Asteri AI">
            <div class="comp">
              <div class="frag f1 statpair" role="img" aria-label="The same dashboard stat card rendered twice, pixel-identical before and after the token migration">
                <div class="stat-card">
                  <span>Active studies</span><b>128</b>
                  <small>before · inline styles</small>
                </div>
                <div class="stat-card">
                  <span>Active studies</span><b>128</b>
                  <small>after · semantic tokens</small>
                </div>
              </div>
              <pre class="frag f2 code" aria-label="The semantic tokens the migrated card consumes"><code>.statCard &#123;
  background: var(--surface-raised);
  border-radius: var(--radius-card);
  padding: var(--space-inset);
&#125;</code></pre>
              <span class="frag f3 chip">Zero visual diff, on purpose</span>
            </div>
            <div class="detail">
              <p class="decision">
                The audit found systemic UI inconsistency. Token infrastructure came first,
                appearance unchanged on purpose: the company’s first design system in production,
                rolling on after the engagement ended.
              </p>
              <p class="meta">Design Engineer · seed-stage startup · six-week engagement · 2026</p>
              <a class="case" href="/work/asteri/">Read the Asteri case study<span aria-hidden="true"> →</span></a>
            </div>
          </section>

          <!-- STARTUPOS -->
          <section class="plate p-startupos" id="p-startupos" data-p="startupos" aria-label="StartupOS">
            <div class="comp">
              <div class="frag f1 shot wide">
                <Image src={unitShot} alt="StartupOS learning unit template: hero, overview, video, contents accordion" widths={[520, 860]} sizes="(max-width: 940px) 74vw, 430px" />
              </div>
              <div class="frag f2 shot inset">
                <Image src={wizardShot} alt="StartupOS Problem-Solution Fit wizard with its experiments list" widths={[320, 520]} sizes="220px" />
              </div>
              <span class="frag f3 chip">MVP in five months</span>
            </div>
            <div class="detail">
              <p class="decision">
                Bespoke lesson designs would have eaten the five-month clock. One reusable
                template, five iterations deep, turned executive churn into a non-event. The MVP
                shipped; Demo Day validated it.
              </p>
              <p class="meta">Product Designer · 2022 · every surface, copy included</p>
              <a class="case" href="/work/startup-platform/">Read the StartupOS case study<span aria-hidden="true"> →</span></a>
            </div>
          </section>

          <!-- ARTPARDE -->
          <section class="plate p-artparde" id="p-artparde" data-p="artparde" aria-label="ArtPärdē">
            <div class="comp">
              <div class="frag f2 shot studies">
                <Image src={studiesStrip} alt="Two shortlisted hand-drawn ArtPärdē wordmark studies" widths={[380, 620]} sizes="250px" />
              </div>
              <div class="frag f1 shot mark">
                <Image src={logoFinal} alt="Final ArtPärdē logo: hand-drawn multicolor letterforms inside a sunburst circle" widths={[380, 640]} sizes="(max-width: 940px) 56vw, 300px" />
              </div>
              <span class="frag f3 chip chip-light">Still their home, two years on</span>
            </div>
            <div class="detail">
              <p class="decision">
                A volunteer-run non-profit doesn’t need custom code, it needs a site volunteers can
                run. The craft budget went to the brand instead. Two years on, nothing has needed
                rescuing.
              </p>
              <p class="meta">Brand &amp; web · San Francisco 501(c)(3) · 2024, ongoing</p>
              <a class="case" href="/work/artparde/">Read the ArtPärdē case study<span aria-hidden="true"> →</span></a>
            </div>
          </section>
        </div>
      </main>

      <footer class="end">
        <a class="mail" href="mailto:joelryerson@gmail.com">joelryerson@gmail.com</a>
        <span>Full-time or contract · July 2026 · East Bay, CA</span>
      </footer>
    </div>

    <script>
      const root = document.documentElement;
      const rail = [...document.querySelectorAll<HTMLAnchorElement>('.rail-item')];
      const plates = [...document.querySelectorAll<HTMLElement>('.plate')];
      const stage = document.getElementById('stage')!;
      const motionOK = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const activate = (id: string, scroll = false) => {
        plates.forEach((p) => p.classList.toggle('active', p.dataset.p === id));
        rail.forEach((r) => {
          if (r.dataset.p === id) r.setAttribute('aria-current', 'true');
          else r.removeAttribute('aria-current');
        });
        if (scroll && window.matchMedia('(max-width: 940px)').matches) {
          stage.scrollIntoView({ behavior: motionOK ? 'smooth' : 'auto', block: 'start' });
        }
      };

      rail.forEach((r) => {
        r.addEventListener('click', (e) => {
          e.preventDefault();
          activate(r.dataset.p!, true);
        });
      });

      // allow deep-linking a state: /experiments/resolve/?p=asteri
      const wanted = new URLSearchParams(location.search).get('p');
      const initial = plates.some((p) => p.dataset.p === wanted) ? wanted! : 'finderly';
      activate(initial);
      // double rAF so the pre-live state paints once, then the first resolve plays;
      // timeout fallback for throttled/hidden tabs where rAF is suspended
      const goLive = () => root.classList.add('live');
      requestAnimationFrame(() => requestAnimationFrame(goLive));
      setTimeout(goLive, 350);
    </script>

    <style>
      @font-face {
        font-family: 'Gambetta X';
        src: url('/fonts/x/gambetta.woff2') format('woff2');
        font-weight: 300 700;
        font-display: swap;
      }
      @font-face {
        font-family: 'Switzer X';
        src: url('/fonts/x/switzer.woff2') format('woff2');
        font-weight: 100 900;
        font-display: swap;
      }

      :root {
        --porcelain: #f5f3ee;
        --ink: #141310;
        --muted: #6c675c;
        --hairline: #dcd8cc;
        --cobalt: #2743d9;
        --serif: 'Gambetta X', Georgia, serif;
        --sans: 'Switzer X', system-ui, sans-serif;
        --settle: cubic-bezier(0.22, 1, 0.36, 1);
        color-scheme: light;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        background: var(--porcelain);
        color: var(--ink);
        font: 400 max(1rem, 16px)/1.6 var(--sans);
        -webkit-font-smoothing: antialiased;
      }

      .ribbon {
        margin: 0;
        padding: 0.5rem 1.2rem;
        background: var(--ink);
        color: var(--porcelain);
        font: 500 max(0.8rem, 13px)/1.4 var(--sans);
        text-align: center;
      }

      .shell {
        max-width: 88rem;
        margin-inline: auto;
        padding: 0 clamp(1.2rem, 4vw, 3.5rem);
      }

      /* ---------- top ---------- */
      .top {
        display: flex;
        align-items: baseline;
        gap: 1.5rem;
        padding: 1.4rem 0 1.1rem;
        border-bottom: 1px solid var(--hairline);
      }
      .wordmark { font: 500 1.15rem/1 var(--serif); letter-spacing: 0.01em; }
      .role { margin-left: auto; font: 450 max(0.88rem, 14px)/1 var(--sans); color: var(--muted); }
      .contact {
        font: 550 max(0.88rem, 14px)/1 var(--sans);
        color: var(--ink);
        text-decoration: none;
        border-bottom: 2px solid var(--cobalt);
        padding-bottom: 2px;
      }
      .contact:hover { color: var(--cobalt); }

      /* ---------- board ---------- */
      .board {
        display: grid;
        grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
        gap: clamp(2rem, 5vw, 5rem);
        align-items: start;
        padding: clamp(2.2rem, 6vh, 4.5rem) 0 clamp(2.5rem, 6vh, 4rem);
      }

      .intro h1 {
        font: 480 clamp(1.7rem, 2.6vw, 2.45rem)/1.22 var(--serif);
        letter-spacing: -0.005em;
        margin: 0 0 1.1rem;
        text-wrap: balance;
      }
      .intro h1 em { font-style: italic; color: var(--cobalt); }
      .value {
        font-size: max(0.98rem, 15px);
        color: var(--muted);
        max-width: 30rem;
        margin: 0 0 2.6rem;
      }

      /* rail */
      .rail-label {
        font: 600 max(0.78rem, 13px)/1 var(--sans);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
        margin: 0 0 0.6rem;
      }
      .rail { list-style: none; margin: 0; padding: 0; }
      .rail li + li { border-top: 1px solid var(--hairline); }
      .rail-item {
        display: grid;
        grid-template-columns: 2.4rem 1fr;
        grid-template-areas: 'no t' 'no d';
        align-items: baseline;
        column-gap: 0.4rem;
        padding: 0.95rem 0.4rem 0.95rem 0;
        text-decoration: none;
        color: var(--muted);
      }
      .rail-item .no {
        grid-area: no;
        font: 550 max(0.82rem, 13px)/1 var(--sans);
        color: var(--muted);
        transition: color 0.25s;
      }
      .rail-item .t {
        grid-area: t;
        font: 520 clamp(1.7rem, 2.6vw, 2.5rem)/1.08 var(--serif);
        letter-spacing: -0.005em;
        color: inherit;
        transition: color 0.25s, transform 0.35s var(--settle);
        transform-origin: left center;
      }
      .rail-item .d {
        grid-area: d;
        font: 450 max(0.84rem, 13.5px)/1.5 var(--sans);
        margin-top: 0.2rem;
      }
      .rail-item:hover { color: var(--ink); }
      .rail-item[aria-current='true'] { color: var(--ink); }
      .rail-item[aria-current='true'] .no { color: var(--cobalt); }
      .rail-item[aria-current='true'] .t { transform: translateX(0.35rem); }
      .rail-item:focus-visible { outline: 2px solid var(--cobalt); outline-offset: 3px; border-radius: 4px; }

      /* ---------- stage ---------- */
      .plate {
        border-radius: 22px;
        overflow: clip;
        margin-bottom: 1.6rem;
      }
      .p-finderly { background: #e6ddef; }
      .p-asteri { background: #e7ebed; }
      .p-startupos { background: #e8e9f4; }
      .p-artparde { background: #17130f; color: #f2ede4; }

      .comp {
        position: relative;
        height: clamp(300px, 30vw, 430px);
        overflow: hidden;
      }
      .frag { position: absolute; }
      .shot img { display: block; width: 100%; height: auto; }

      /* finderly composition */
      .p-finderly .main {
        left: 12%;
        top: 8%;
        width: clamp(190px, 21vw, 285px);
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 24px 50px rgba(20, 19, 16, 0.22);
      }
      .p-finderly .capture {
        right: 11%;
        top: 10%;
        width: clamp(115px, 11.5vw, 160px);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 18px 40px rgba(20, 19, 16, 0.2);
      }

      /* asteri composition */
      .p-asteri .statpair {
        left: 9%;
        top: 16%;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        width: min(56%, 460px);
      }
      .stat-card {
        background: #f7f8fa;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 18px;
        display: grid;
        gap: 2px;
        box-shadow: 0 16px 36px rgba(20, 19, 16, 0.1);
      }
      .stat-card span { color: #6b7280; font-size: 13px; }
      .stat-card b { color: #111827; font-size: 26px; font-weight: 600; }
      .stat-card small { color: #9ca3af; font-size: 11.5px; margin-top: 8px; }
      .p-asteri .code {
        right: 8%;
        bottom: 10%;
        margin: 0;
        background: #14171a;
        color: #d7dde3;
        border-radius: 12px;
        padding: 0.9rem 1.1rem;
        font: 400 max(0.72rem, 11.5px)/1.6 ui-monospace, Menlo, monospace;
        box-shadow: 0 18px 40px rgba(20, 19, 16, 0.22);
      }

      /* startupos composition */
      .p-startupos .wide {
        left: 7%;
        top: 10%;
        width: min(58%, 430px);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 20px 44px rgba(20, 19, 16, 0.18);
      }
      .p-startupos .inset {
        right: 8%;
        bottom: -8%;
        width: clamp(160px, 17vw, 230px);
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 18px 40px rgba(20, 19, 16, 0.2);
      }

      /* artparde composition */
      .p-artparde .mark {
        left: 10%;
        top: 12%;
        width: clamp(200px, 22vw, 300px);
      }
      .p-artparde .studies {
        right: 7%;
        bottom: 12%;
        width: clamp(170px, 19vw, 260px);
        border-radius: 10px;
        overflow: hidden;
        opacity: 0.9;
      }

      .chip {
        bottom: 9%;
        background: rgba(20, 19, 16, 0.82);
        color: var(--porcelain);
        font: 550 max(0.8rem, 13px)/1 var(--sans);
        padding: 0.55rem 0.95rem;
        border-radius: 999px;
        white-space: nowrap;
      }
      .p-finderly .chip { right: 8%; bottom: 9%; }
      .p-asteri .chip { left: 9%; bottom: 14%; }
      .p-startupos .chip { left: 10%; bottom: 14%; }
      .chip-light { background: rgba(242, 237, 228, 0.92); color: var(--ink); left: 10%; bottom: 8%; }

      /* detail */
      .detail { padding: 1.6rem clamp(1.4rem, 3vw, 2.4rem) 1.9rem; }
      .decision {
        font: 480 clamp(1.12rem, 1.6vw, 1.38rem)/1.5 var(--serif);
        margin: 0 0 0.8rem;
        max-width: 42rem;
      }
      .meta { font: 450 max(0.85rem, 13.5px)/1.5 var(--sans); color: var(--muted); margin: 0 0 1.1rem; }
      .p-artparde .meta { color: #b5ad9e; }
      .case {
        font: 600 max(0.92rem, 14.5px)/1 var(--sans);
        color: inherit;
        text-decoration: none;
        border-bottom: 2px solid var(--cobalt);
        padding-bottom: 2px;
      }
      .case:hover { color: var(--cobalt); }
      .p-artparde .case:hover { color: #9fb0ff; }

      /* ---------- live mode: plates become one stage ---------- */
      .live .stage { display: grid; }
      .live .plate {
        grid-area: 1 / 1;
        margin-bottom: 0;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.42s ease, visibility 0s 0.45s;
      }
      .live .plate.active {
        opacity: 1;
        visibility: visible;
        transition: opacity 0.42s ease, visibility 0s;
      }
      /* fragments resolve into place */
      .live .frag {
        opacity: 0;
        transition:
          transform 0.55s var(--settle),
          opacity 0.4s ease;
      }
      .live .f1 { transform: translate(-26px, 10px); }
      .live .f2 { transform: translate(30px, -12px); }
      .live .f3 { transform: translateY(14px); }
      .live .plate.active .f1 { opacity: 1; transform: none; transition-delay: 0.06s; }
      .live .plate.active .f2 { opacity: 1; transform: none; transition-delay: 0.16s; }
      .live .plate.active .f3 { opacity: 1; transform: none; transition-delay: 0.28s; }
      /* detail follows the composition */
      .live .detail { opacity: 0; transform: translateY(8px); transition: opacity 0.4s ease, transform 0.5s var(--settle); }
      .live .plate.active .detail { opacity: 1; transform: none; transition-delay: 0.2s; }

      @media (prefers-reduced-motion: reduce) {
        .live .plate, .live .frag, .live .detail { transition: none !important; }
        .live .f1, .live .f2, .live .f3 { transform: none; }
        .rail-item .t { transition: none; }
      }

      /* ---------- footer ---------- */
      .end {
        display: flex;
        align-items: baseline;
        gap: 1.4rem;
        flex-wrap: wrap;
        border-top: 1px solid var(--hairline);
        padding: 1.3rem 0 2.2rem;
        color: var(--muted);
        font-size: max(0.88rem, 14px);
      }
      .mail {
        font: 520 1.05rem/1 var(--serif);
        color: var(--ink);
        text-decoration: none;
        border-bottom: 2px solid var(--cobalt);
        padding-bottom: 2px;
      }
      .mail:hover { color: var(--cobalt); }

      /* ---------- mobile ---------- */
      @media (max-width: 940px) {
        .top { flex-wrap: wrap; gap: 0.6rem 1.5rem; }
        .role { margin-left: 0; order: 3; width: 100%; }
        .board { grid-template-columns: 1fr; gap: 2.4rem; padding-top: 2rem; }
        .value { margin-bottom: 1.8rem; }
        .rail-item { padding-block: 0.8rem; }
        .comp { height: clamp(280px, 78vw, 420px); }
        .p-finderly .main { width: clamp(170px, 44vw, 230px); left: 7%; }
        .p-finderly .capture { width: clamp(115px, 30vw, 160px); right: 7%; }
        .p-asteri .statpair { width: 84%; left: 8%; top: 10%; }
        .p-asteri .code { right: 6%; bottom: 8%; }
        .p-startupos .wide { width: 74%; left: 5%; }
        .p-startupos .inset { width: clamp(140px, 38vw, 190px); right: 5%; }
        .p-artparde .mark { width: clamp(170px, 46vw, 230px); }
        .p-artparde .studies { width: clamp(140px, 38vw, 200px); }
        .stage { scroll-margin-top: 0.8rem; }
      }
      @media (max-width: 480px) {
        .p-asteri .code { display: none; }
        .chip, .p-finderly .chip { white-space: normal; text-align: center; }
      }
    </style>
  </body>
</html>
